@model CreateFaultViewModel
@using EquipmentRental.Models
@using EquipmentRental.Models.ViewModels
@{
    ViewData["Title"] = "故障上报";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">故障上报</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">返回列表</a>
</div>

<div class="alert alert-warning mb-4 small">
    <strong>调度单 #@Model.OrderId</strong> &nbsp;|&nbsp;
    项目：@Model.ProjectName &nbsp;|&nbsp;
    设备编号：<code>@Model.EquipmentNo</code>
    <br />
    <span class="text-danger fw-semibold">提交后设备将自动标记为「维修中」，请确认信息无误。</span>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <div>@err.ErrorMessage</div>
        }
    </div>
}

<form asp-action="Create" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="OrderId" />
    <input type="hidden" name="ProjectName" value="@Model.ProjectName" />
    <input type="hidden" name="EquipmentNo" value="@Model.EquipmentNo" />

    <div class="row g-4">
        <!-- 左列：故障信息 -->
        <div class="col-lg-8">
            <div class="card mb-4">
                <div class="card-header fw-semibold">故障信息</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">故障描述 <span class="text-danger">*</span></label>
                        <textarea asp-for="Description" rows="5" class="form-control"
                                  placeholder="详细描述故障现象、发现时间及位置" maxlength="500"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                        <div class="text-muted small mt-1">最多 500 字</div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label">严重程度 <span class="text-danger">*</span></label>
                        <div class="btn-group w-100" role="group">
                            <input type="radio" class="btn-check" name="Severity" id="sev1" value="1"
                                   @(Model.Severity == FaultSeverity.Minor ? "checked" : "") />
                            <label class="btn btn-outline-info" for="sev1">轻微</label>

                            <input type="radio" class="btn-check" name="Severity" id="sev2" value="2"
                                   @(Model.Severity == FaultSeverity.Medium ? "checked" : "") />
                            <label class="btn btn-outline-warning" for="sev2">中等</label>

                            <input type="radio" class="btn-check" name="Severity" id="sev3" value="3"
                                   @(Model.Severity == FaultSeverity.Severe ? "checked" : "") />
                            <label class="btn btn-outline-danger" for="sev3">严重</label>
                        </div>
                        <span asp-validation-for="Severity" class="text-danger small d-block mt-1"></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- 右列：照片 + 提交 -->
        <div class="col-lg-4">
            <div class="card mb-4">
                <div class="card-header fw-semibold">故障照片（最多 10 张）</div>
                <div class="card-body">
                    <input type="file" name="Images" id="file-input"
                           class="form-control form-control-sm"
                           multiple accept=".jpg,.jpeg,.png" />
                    <div id="file-count" class="text-muted small mt-1"></div>
                </div>
            </div>

            <button type="submit" class="btn btn-danger w-100">提交故障上报</button>
        </div>
    </div>
</form>

@section Scripts {
<script>
(function () {
    $('#file-input').on('change', function () {
        const n = this.files.length;
        if (n > 10) {
            $('#file-count').text('最多 10 张照片，请重新选择').addClass('text-danger').removeClass('text-muted');
        } else {
            $('#file-count').text('已选择 ' + n + ' 张').removeClass('text-danger').addClass('text-muted');
        }
    });
})();
</script>
}
