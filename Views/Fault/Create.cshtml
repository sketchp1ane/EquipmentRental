@model CreateFaultViewModel
@using EquipmentRental.Models
@using EquipmentRental.Models.ViewModels
@{
    ViewData["Title"] = "故障上报";
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h4 class="mb-0"><i class="bi bi-exclamation-triangle text-danger me-2"></i>故障上报</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>返回列表
    </a>
</div>

<div class="alert alert-warning mb-4 small d-flex align-items-start gap-2">
    <i class="bi bi-info-circle-fill mt-1"></i>
    <div>
        <strong>调度单 #@Model.OrderId</strong> &nbsp;|&nbsp;
        项目：@Model.ProjectName &nbsp;|&nbsp;
        设备编号：<code>@Model.EquipmentNo</code>
        <br />
        <span class="text-danger fw-semibold">提交后设备将自动标记为「维修中」，请确认信息无误。</span>
    </div>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger py-2 small">
        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <div>@err.ErrorMessage</div>
        }
    </div>
}

<form asp-action="Create" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="OrderId" />
    <input type="hidden" name="ProjectName" value="@Model.ProjectName" />
    <input type="hidden" name="EquipmentNo" value="@Model.EquipmentNo" />

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="er-card p-3 p-md-4 mb-4">
                <h5 class="mb-3"><i class="bi bi-card-text me-2"></i>故障信息</h5>

                <div class="mb-3">
                    <label class="form-label er-required">故障描述</label>
                    <textarea asp-for="Description" rows="5" class="form-control"
                              placeholder="详细描述故障现象、发现时间及位置" maxlength="500"></textarea>
                    <div class="d-flex justify-content-between">
                        <span asp-validation-for="Description" class="text-danger small"></span>
                        <small class="text-muted">最多 500 字</small>
                    </div>
                </div>

                <div class="mb-2">
                    <label class="form-label er-required">严重程度</label>
                    <div class="btn-group w-100 flex-wrap" role="group">
                        <input type="radio" class="btn-check" name="Severity" id="sev1" value="1"
                               @(Model.Severity == FaultSeverity.Minor ? "checked" : "") />
                        <label class="btn btn-outline-info" for="sev1">
                            <i class="bi bi-info-circle me-1"></i>轻微
                        </label>

                        <input type="radio" class="btn-check" name="Severity" id="sev2" value="2"
                               @(Model.Severity == FaultSeverity.Medium ? "checked" : "") />
                        <label class="btn btn-outline-warning" for="sev2">
                            <i class="bi bi-exclamation-triangle me-1"></i>中等
                        </label>

                        <input type="radio" class="btn-check" name="Severity" id="sev3" value="3"
                               @(Model.Severity == FaultSeverity.Severe ? "checked" : "") />
                        <label class="btn btn-outline-danger" for="sev3">
                            <i class="bi bi-x-octagon me-1"></i>严重
                        </label>
                    </div>
                    <span asp-validation-for="Severity" class="text-danger small d-block mt-1"></span>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="er-card p-3 mb-4">
                <h6 class="mb-2"><i class="bi bi-image me-2"></i>故障照片</h6>
                <div class="small text-muted mb-2">最多 10 张，支持 JPG / PNG</div>
                <label for="file-input" class="er-dropzone d-flex flex-column align-items-center justify-content-center text-muted">
                    <i class="bi bi-cloud-upload" style="font-size:1.75rem"></i>
                    <div class="mt-1 small">点击选择或拖拽</div>
                    <input type="file" name="Images" id="file-input"
                           class="d-none" multiple accept=".jpg,.jpeg,.png" />
                </label>
                <div id="file-count" class="text-muted small mt-2"></div>
            </div>

            <button type="submit" class="btn btn-danger w-100">
                <i class="bi bi-send me-1"></i>提交故障上报
            </button>
        </div>
    </div>
</form>

@section Scripts {
<script>
(function () {
    $('#file-input').on('change', function () {
        const n = this.files.length;
        if (n > 10) {
            $('#file-count').text('最多 10 张照片，请重新选择').addClass('text-danger').removeClass('text-muted');
        } else {
            $('#file-count').text('已选择 ' + n + ' 张').removeClass('text-danger').addClass('text-muted');
        }
    });
})();
</script>
}
