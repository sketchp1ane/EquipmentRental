@model FaultListViewModel
@using EquipmentRental.Constants
@using EquipmentRental.Models
@using EquipmentRental.Models.ViewModels
@{
    ViewData["Title"] = "故障工单";

    (string Key, string Text) SeverityVm(FaultSeverity s) => s switch
    {
        FaultSeverity.Minor  => ("Info",      "轻微"),
        FaultSeverity.Medium => ("Expiring",  "中等"),
        FaultSeverity.Severe => ("Danger",    "严重"),
        _                    => ("Draft",     s.ToString())
    };

    (string Key, string Text) StatusVm(FaultStatus s) => s switch
    {
        FaultStatus.Pending    => ("Draft",    "待处理"),
        FaultStatus.InProgress => ("InUse",    "处理中"),
        FaultStatus.Closed     => ("Success",  "已关闭"),
        _                      => ("Draft",    s.ToString())
    };
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h4 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>故障工单</h4>
    @if (User.IsInRole(Roles.SafetyOfficer) || User.IsInRole(Roles.ProjectLead) || User.IsInRole(Roles.Admin))
    {
        <div class="dropdown">
            <button class="btn btn-danger btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown"
                    @(Model.AvailableOrders.Count == 0 ? "disabled" : "")>
                <i class="bi bi-plus-lg me-1"></i>故障上报
                @if (Model.AvailableOrders.Count > 0)
                {
                    <span class="badge bg-light text-dark ms-1">共 @Model.AvailableOrders.Count 个可选</span>
                }
            </button>
            <ul class="dropdown-menu dropdown-menu-end" style="max-height: 320px; overflow-y: auto;">
                @if (Model.AvailableOrders.Count == 0)
                {
                    <li><span class="dropdown-item-text text-muted small">暂无进行中的调度单</span></li>
                }
                else
                {
                    <li><h6 class="dropdown-header">选择一张进行中的调度单</h6></li>
                    @foreach (var opt in Model.AvailableOrders)
                    {
                        <li>
                            <a class="dropdown-item" asp-action="Create" asp-route-orderId="@opt.OrderId">
                                <div class="small">#@opt.OrderId · @opt.ProjectName</div>
                                <div class="text-muted small"><code>@opt.EquipmentNo</code> @opt.EquipmentName</div>
                            </a>
                        </li>
                    }
                }
            </ul>
        </div>
    }
</div>

@if (Model.Items.Any())
{
    <div class="table-responsive">
        <table class="table table-hover table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>调度单</th>
                    <th class="d-none d-md-table-cell">项目名称</th>
                    <th>设备编号</th>
                    <th>严重程度</th>
                    <th class="d-none d-lg-table-cell">上报人</th>
                    <th class="d-none d-xl-table-cell">上报时间</th>
                    <th>状态</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td class="text-muted small">#@item.Id</td>
                        <td>
                            <a asp-controller="Dispatch" asp-action="OrderDetails" asp-route-id="@item.OrderId">#@item.OrderId</a>
                        </td>
                        <td class="text-truncate-2 d-none d-md-table-cell" style="max-width:200px">@item.ProjectName</td>
                        <td><code>@item.EquipmentNo</code></td>
                        <td>
                            @{ var (sk, st) = SeverityVm(item.Severity); }
                            @await Html.PartialAsync("_StatusBadge", (Key: sk, Text: st))
                        </td>
                        <td class="text-muted small d-none d-lg-table-cell">@item.ReporterName</td>
                        <td class="text-muted small text-nowrap d-none d-xl-table-cell">@item.ReportedAt.ToLocalTime().ToDateTimeStr()</td>
                        <td>
                            @{ var (k, t) = StatusVm(item.Status); }
                            @await Html.PartialAsync("_StatusBadge", (Key: k, Text: t))
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id"
                               class="btn btn-outline-secondary btn-sm" title="详情" data-bs-toggle="tooltip">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    @await Html.PartialAsync("_EmptyState", (
        Icon: "bi-exclamation-triangle",
        Title: "暂无故障工单",
        Hint: "尚未有故障上报记录",
        CtaText: (string?)null,
        CtaUrl: (string?)null
    ))
}

@await Html.PartialAsync("_Pagination", new PaginationViewModel
{
    Page = Model.Page,
    TotalPages = Model.TotalPages,
    TotalCount = Model.TotalCount,
    RouteValues = new Dictionary<string, string?>()
})
