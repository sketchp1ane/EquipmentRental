@model FaultListViewModel
@using EquipmentRental.Models
@using EquipmentRental.Models.ViewModels
@{
    ViewData["Title"] = "故障工单";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">故障工单</h4>
</div>

@if (Model.Items.Count == 0)
{
    <div class="text-center py-5 text-muted">暂无故障工单</div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>调度单</th>
                        <th>项目名称</th>
                        <th>设备编号</th>
                        <th>严重程度</th>
                        <th>上报人</th>
                        <th>上报时间</th>
                        <th>状态</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>#@item.Id</td>
                            <td>
                                <a asp-controller="Dispatch" asp-action="OrderDetails" asp-route-id="@item.OrderId">#@item.OrderId</a>
                            </td>
                            <td>@item.ProjectName</td>
                            <td><code>@item.EquipmentNo</code></td>
                            <td>
                                @switch (item.Severity)
                                {
                                    case FaultSeverity.Minor:
                                        <span class="badge bg-info text-dark">轻微</span>
                                        break;
                                    case FaultSeverity.Medium:
                                        <span class="badge bg-warning text-dark">中等</span>
                                        break;
                                    case FaultSeverity.Severe:
                                        <span class="badge bg-danger">严重</span>
                                        break;
                                }
                            </td>
                            <td>@item.ReporterName</td>
                            <td>@item.ReportedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                @switch (item.Status)
                                {
                                    case FaultStatus.Pending:
                                        <span class="badge bg-secondary">待处理</span>
                                        break;
                                    case FaultStatus.InProgress:
                                        <span class="badge bg-primary">处理中</span>
                                        break;
                                    case FaultStatus.Closed:
                                        <span class="badge bg-success">已关闭</span>
                                        break;
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-outline-secondary btn-sm">详情</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination pagination-sm justify-content-center">
                @for (int p = 1; p <= Model.TotalPages; p++)
                {
                    <li class="page-item @(p == Model.Page ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@p">@p</a>
                    </li>
                }
            </ul>
        </nav>
    }

    <div class="text-muted small text-end mt-2">共 @Model.TotalCount 条记录</div>
}
