@model VerificationDetailViewModel
@using EquipmentRental.Models.ViewModels
@{
    ViewData["Title"] = $"核验结果 #{Model.Id}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">核验结果 <small class="text-muted fs-6">#@Model.Id</small></h4>
    <a asp-action="List" class="btn btn-outline-secondary btn-sm">返回列表</a>
</div>

<!-- 核验结论横幅 -->
@if (Model.IsPass)
{
    <div class="alert alert-success d-flex align-items-center gap-3 mb-4">
        <span style="font-size:2rem;">&#10003;</span>
        <div>
            <div class="fw-semibold fs-5">核验通过</div>
            <div class="small">设备已完成进场核验，可进入下一环节。</div>
        </div>
    </div>
}
else
{
    <div class="alert alert-danger d-flex align-items-center gap-3 mb-4">
        <span style="font-size:2rem;">&#10007;</span>
        <div>
            <div class="fw-semibold fs-5">核验未通过</div>
            @if (!string.IsNullOrEmpty(Model.FailReason))
            {
                <div class="small">@Model.FailReason</div>
            }
        </div>
    </div>
}

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card mb-3">
            <div class="card-header fw-semibold">调度单信息</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">调度单</dt>
                    <dd class="col-sm-8">
                        <a asp-controller="Dispatch" asp-action="OrderDetails" asp-route-id="@Model.OrderId">#@Model.OrderId</a>
                    </dd>
                    <dt class="col-sm-4">项目名称</dt>
                    <dd class="col-sm-8">@Model.ProjectName</dd>
                    <dt class="col-sm-4">设备编号</dt>
                    <dd class="col-sm-8"><code>@Model.EquipmentNo</code> @Model.EquipmentName</dd>
                    <dt class="col-sm-4">租赁期间</dt>
                    <dd class="col-sm-8">@Model.ActualStart.ToString("yyyy-MM-dd") 至 @Model.ActualEnd.ToString("yyyy-MM-dd")</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card">
            <div class="card-header fw-semibold">核验信息</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">核验人员</dt>
                    <dd class="col-sm-7">@Model.VerifierName</dd>
                    <dt class="col-sm-5">核验时间</dt>
                    <dd class="col-sm-7">@Model.VerifiedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</dd>
                    <dt class="col-sm-5">核验结果</dt>
                    <dd class="col-sm-7">
                        @if (Model.IsPass)
                        {
                            <span class="badge bg-success">通过</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">未通过</span>
                        }
                    </dd>
                    @if (!Model.IsPass && !string.IsNullOrEmpty(Model.FailReason))
                    {
                        <dt class="col-sm-5">失败原因</dt>
                        <dd class="col-sm-7 text-danger">@Model.FailReason</dd>
                    }
                </dl>
            </div>
        </div>
    </div>
</div>
