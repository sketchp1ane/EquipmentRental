@model VerificationListViewModel
@using EquipmentRental.Models.ViewModels
@{
    ViewData["Title"] = "核验记录";
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h4 class="mb-0"><i class="bi bi-clipboard2-check me-2"></i>进场核验记录</h4>
    @if (User.IsInRole(EquipmentRental.Constants.Roles.ProjectLead) ||
         User.IsInRole(EquipmentRental.Constants.Roles.Admin))
    {
        <a asp-action="Verify" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>新建核验
        </a>
    }
</div>

@if (Model.Items.Any())
{
    <div class="table-responsive">
        <table class="table table-hover table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th>调度单</th>
                    <th>设备编号</th>
                    <th class="d-none d-md-table-cell">项目名称</th>
                    <th class="d-none d-lg-table-cell">核验人员</th>
                    <th>核验时间</th>
                    <th>结果</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>
                            <a asp-controller="Dispatch" asp-action="OrderDetails" asp-route-id="@item.OrderId">#@item.OrderId</a>
                        </td>
                        <td><code>@item.EquipmentNo</code></td>
                        <td class="text-truncate-2 d-none d-md-table-cell" style="max-width:200px">@item.ProjectName</td>
                        <td class="text-muted small d-none d-lg-table-cell">@item.VerifierName</td>
                        <td class="text-muted small text-nowrap">@item.VerifiedAt.ToLocalTime().ToDateTimeStr()</td>
                        <td>
                            @if (item.IsPass)
                            {
                                @await Html.PartialAsync("_StatusBadge", (Key: "Success", Text: "通过"))
                            }
                            else
                            {
                                @await Html.PartialAsync("_StatusBadge", (Key: "Danger", Text: "未通过"))
                            }
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id"
                               class="btn btn-outline-secondary btn-sm" title="详情" data-bs-toggle="tooltip">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    @await Html.PartialAsync("_EmptyState", (
        Icon: "bi-clipboard2-check",
        Title: "暂无核验记录",
        Hint: "尚未有进场核验记录",
        CtaText: (string?)null,
        CtaUrl: (string?)null
    ))
}

@await Html.PartialAsync("_Pagination", new PaginationViewModel
{
    Page = Model.Page,
    TotalPages = Model.TotalPages,
    TotalCount = Model.TotalCount,
    ActionName = "List",
    RouteValues = new Dictionary<string, string?>()
})
