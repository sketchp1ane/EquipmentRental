@model CategoryListViewModel
@{
    ViewData["Title"] = "设备分类管理";
    bool hasModalError = !ViewData.ModelState.IsValid;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">设备分类管理</h4>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-primary btn-sm"
                data-bs-toggle="modal" data-bs-target="#createModal">
            + 新增分类
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">设备列表</a>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-hover table-sm align-middle">
        <thead class="table-light">
            <tr>
                <th>分类名称</th>
                <th>上级分类</th>
                <th>层级</th>
                <th>排序</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        <span style="padding-left: @((item.Level - 1) * 20)px">
                            @if (item.Level > 1) { <text>└ </text> }
                            @item.Name
                        </span>
                    </td>
                    <td class="text-muted small">@(item.ParentName ?? "—")</td>
                    <td>@item.Level</td>
                    <td>@item.SortOrder</td>
                    <td>
                        <a asp-action="EditCategory" asp-route-id="@item.Id"
                           class="btn btn-outline-primary btn-sm">编辑</a>
                        @if (!item.HasChildren && !item.HasEquipments)
                        {
                            <form asp-action="DeleteCategory" asp-route-id="@item.Id"
                                  method="post" class="d-inline"
                                  onsubmit="return confirm('确认删除分类「@item.Name」？')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm">删除</button>
                            </form>
                        }
                        else
                        {
                            <span class="text-muted small ms-1">
                                @(item.HasChildren ? "有子分类" : "有设备")
                            </span>
                        }
                    </td>
                </tr>
            }
            @if (!Model.Items.Any())
            {
                <tr>
                    <td colspan="5" class="text-center text-muted py-4">暂无分类，请先新增</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- 新增分类 Modal -->
<div class="modal fade @(hasModalError ? "show" : "")" id="createModal" tabindex="-1"
     aria-labelledby="createModalLabel" aria-hidden="@(!hasModalError ? "true" : "false")"
     @(hasModalError ? "style=display:block;" : "")>
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="createModalLabel">新增分类</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"
                        aria-label="Close"></button>
            </div>
            <form asp-action="CreateCategory" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    @Html.ValidationSummary(true, "", new { @class = "alert alert-danger py-2 small" })

                    <div class="mb-3">
                        <label asp-for="Form.Name" class="form-label"></label>
                        <input asp-for="Form.Name" class="form-control form-control-sm" />
                        <span asp-validation-for="Form.Name" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Form.ParentId" class="form-label"></label>
                        <select asp-for="Form.ParentId" asp-items="Model.Form.ParentOptions"
                                class="form-select form-select-sm">
                            <option value="">无上级分类</option>
                        </select>
                    </div>
                    <div class="row g-3">
                        <div class="col-6">
                            <label asp-for="Form.Level" class="form-label"></label>
                            <input asp-for="Form.Level" type="number" min="1" max="5"
                                   class="form-control form-control-sm" />
                            <span asp-validation-for="Form.Level" class="text-danger small"></span>
                        </div>
                        <div class="col-6">
                            <label asp-for="Form.SortOrder" class="form-label"></label>
                            <input asp-for="Form.SortOrder" type="number" min="0"
                                   class="form-control form-control-sm" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm"
                            data-bs-dismiss="modal">取消</button>
                    <button type="submit" class="btn btn-primary btn-sm">保存</button>
                </div>
            </form>
        </div>
    </div>
</div>
@if (hasModalError)
{
    <div class="modal-backdrop fade show"></div>
}

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    @if (hasModalError)
    {
        <script>
            var modal = new bootstrap.Modal(document.getElementById('createModal'));
            modal.show();
        </script>
    }
}
