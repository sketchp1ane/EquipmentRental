@model CategoryFormViewModel
@{
    ViewData["Title"] = "编辑分类";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">编辑分类</h4>
    <a asp-action="Categories" class="btn btn-outline-secondary btn-sm">返回分类列表</a>
</div>

<div class="card" style="max-width:480px">
    <div class="card-body">
        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger py-2 small" })

        <form asp-action="EditCategory" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control form-control-sm" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ParentId" class="form-label"></label>
                <select asp-for="ParentId" asp-items="Model.ParentOptions"
                        class="form-select form-select-sm">
                    <option value="">无上级分类</option>
                </select>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-6">
                    <label asp-for="Level" class="form-label"></label>
                    <input asp-for="Level" type="number" min="1" max="5"
                           class="form-control form-control-sm" />
                    <span asp-validation-for="Level" class="text-danger small"></span>
                </div>
                <div class="col-6">
                    <label asp-for="SortOrder" class="form-label"></label>
                    <input asp-for="SortOrder" type="number" min="0"
                           class="form-control form-control-sm" />
                </div>
            </div>

            <button type="submit" class="btn btn-primary">保存修改</button>
            <a asp-action="Categories" class="btn btn-outline-secondary ms-2">取消</a>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
