@model EquipmentListViewModel
@{
    ViewData["Title"] = "设备台账";
    bool canWrite  = User.IsInRole(Roles.Admin) || User.IsInRole(Roles.DeviceAdmin);
    bool canExport = canWrite || User.IsInRole(Roles.Auditor);

    (string Key, string Text) StatusVm(EquipmentStatus s) => s switch
    {
        EquipmentStatus.PendingReview => ("Pending",     "待审核"),
        EquipmentStatus.Idle          => ("Idle",        "闲置"),
        EquipmentStatus.InUse         => ("InUse",       "使用中"),
        EquipmentStatus.Maintenance   => ("Maintenance", "维修中"),
        EquipmentStatus.Scrapped      => ("Cancelled",   "已报废"),
        _                             => ("Draft",       s.ToString())
    };
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h4 class="mb-0"><i class="bi bi-box-seam me-2"></i>设备台账</h4>
    <div class="d-flex gap-2">
        @if (canExport)
        {
            <a asp-action="Export"
               asp-route-categoryId="@Model.CategoryId"
               asp-route-status="@Model.Status"
               asp-route-keyword="@Model.Keyword"
               class="btn btn-outline-success btn-sm">
                <i class="bi bi-download me-1"></i>导出 Excel
            </a>
        }
        @if (canWrite)
        {
            <a asp-action="Create" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg me-1"></i>设备入库
            </a>
            <a asp-action="Categories" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-tags me-1"></i>分类管理
            </a>
        }
    </div>
</div>

<!-- 筛选栏 -->
<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <input type="text" name="keyword" value="@Model.Keyword"
               class="form-control form-control-sm" placeholder="编号 / 名称 / 品牌型号" />
    </div>
    <div class="col-auto">
        <select name="categoryId" class="form-select form-select-sm">
            <option value="">全部分类</option>
            @{
                var catGroups = Model.CategoryOptions
                    .GroupBy(o => o.Group?.Name)
                    .ToList();
            }
            @foreach (var grp in catGroups)
            {
                if (grp.Key != null)
                {
                    <optgroup label="@grp.Key">
                        @foreach (var opt in grp)
                        {
                            <option value="@opt.Value"
                                    selected="@(Model.CategoryId?.ToString() == opt.Value)">@opt.Text</option>
                        }
                    </optgroup>
                }
                else
                {
                    @foreach (var opt in grp)
                    {
                        <option value="@opt.Value"
                                selected="@(Model.CategoryId?.ToString() == opt.Value)">@opt.Text</option>
                    }
                }
            }
        </select>
    </div>
    <div class="col-auto">
        <select name="status" class="form-select form-select-sm">
            <option value="">全部状态</option>
            <option value="0" selected="@(Model.Status == EquipmentStatus.PendingReview)">待审核</option>
            <option value="1" selected="@(Model.Status == EquipmentStatus.Idle)">闲置</option>
            <option value="2" selected="@(Model.Status == EquipmentStatus.InUse)">使用中</option>
            <option value="3" selected="@(Model.Status == EquipmentStatus.Maintenance)">维修中</option>
            <option value="4" selected="@(Model.Status == EquipmentStatus.Scrapped)">已报废</option>
        </select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary btn-sm">
            <i class="bi bi-funnel me-1"></i>筛选
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">重置</a>
    </div>
</form>

<!-- 设备表格 -->
@if (Model.Items.Any())
{
    <div class="table-responsive">
        <table class="table table-hover table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th style="min-width:120px">设备编号</th>
                    <th style="min-width:140px">设备名称</th>
                    <th style="min-width:100px">分类</th>
                    <th style="min-width:160px">品牌/型号</th>
                    <th style="min-width:100px">状态</th>
                    <th style="min-width:110px">录入时间</th>
                    <th style="min-width:140px">操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td><code>@item.EquipmentNo</code></td>
                        <td class="text-truncate-2" style="max-width:180px">@item.Name</td>
                        <td class="text-muted small">@item.CategoryName</td>
                        <td class="text-muted small text-truncate-2" style="max-width:220px">@item.BrandModel</td>
                        <td>
                            @{ var (k, t) = StatusVm(item.Status); }
                            @await Html.PartialAsync("_StatusBadge", (Key: k, Text: t))
                        </td>
                        <td class="text-muted small">@item.CreatedAt.ToDateStr()</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id"
                               class="btn btn-outline-secondary btn-sm" title="详情" data-bs-toggle="tooltip">
                                <i class="bi bi-eye"></i>
                            </a>
                            @if (canWrite)
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id"
                                   class="btn btn-outline-primary btn-sm" title="编辑" data-bs-toggle="tooltip">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    @await Html.PartialAsync("_EmptyState", (
        Icon: "bi-box-seam",
        Title: "暂无设备",
        Hint: canWrite ? "点击右上角「设备入库」开始录入" : "当前筛选条件下无匹配设备",
        CtaText: canWrite ? "设备入库" : null,
        CtaUrl: canWrite ? Url.Action("Create") : null
    ))
}

@await Html.PartialAsync("_Pagination", new PaginationViewModel
{
    Page = Model.Page,
    TotalPages = Model.TotalPages,
    TotalCount = Model.TotalCount,
    RouteValues = new Dictionary<string, string?>
    {
        ["keyword"]    = Model.Keyword,
        ["categoryId"] = Model.CategoryId?.ToString(),
        ["status"]     = Model.Status?.ToString()
    }
})
