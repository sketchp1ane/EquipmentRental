@model EditEquipmentViewModel
@{
    ViewData["Title"] = "编辑设备";
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h4 class="mb-0"><i class="bi bi-pencil-square me-2"></i>编辑设备</h4>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>返回详情
    </a>
</div>

<div class="er-card">
    @Html.ValidationSummary(true, "", new { @class = "alert alert-danger py-2 small" })

    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <fieldset class="mb-4">
            <legend class="fs-6 fw-semibold text-muted border-bottom pb-1 mb-3">基本信息</legend>

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="EquipmentNo" class="form-label er-required"></label>
                    <input asp-for="EquipmentNo" class="form-control" />
                    <span asp-validation-for="EquipmentNo" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Name" class="form-label er-required"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="CategoryId" class="form-label er-required"></label>
                    <select asp-for="CategoryId" asp-items="Model.CategoryOptions" class="form-select">
                        <option value="">请选择分类</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="BrandModel" class="form-label er-required"></label>
                    <input asp-for="BrandModel" class="form-control" />
                    <span asp-validation-for="BrandModel" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="FactoryNo" class="form-label"></label>
                    <input asp-for="FactoryNo" class="form-control" />
                    <span asp-validation-for="FactoryNo" class="text-danger small"></span>
                </div>
            </div>
        </fieldset>

        <fieldset class="mb-4">
            <legend class="fs-6 fw-semibold text-muted border-bottom pb-1 mb-3">时间与价值</legend>

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="ManufactureDate" class="form-label er-required"></label>
                    <input asp-for="ManufactureDate" type="date" class="form-control" />
                    <span asp-validation-for="ManufactureDate" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="PurchaseDate" class="form-label"></label>
                    <input asp-for="PurchaseDate" type="date" class="form-control" />
                    <span asp-validation-for="PurchaseDate" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="OriginalValue" class="form-label"></label>
                    <input asp-for="OriginalValue" type="number" step="0.01" min="0" class="form-control" />
                    <span asp-validation-for="OriginalValue" class="text-danger small"></span>
                </div>
            </div>
        </fieldset>

        <fieldset class="mb-4">
            <legend class="fs-6 fw-semibold text-muted border-bottom pb-1 mb-3">归属与状态</legend>

            <div class="row g-3">
                <div class="col-md-8">
                    <label asp-for="OwnedBy" class="form-label er-required"></label>
                    <input asp-for="OwnedBy" class="form-control" />
                    <span asp-validation-for="OwnedBy" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Status" class="form-label"></label>
                    <select asp-for="Status" class="form-select">
                        <option value="0">待审核</option>
                        <option value="1">闲置</option>
                        <option value="2">使用中</option>
                        <option value="3">维修中</option>
                        <option value="4">已报废</option>
                    </select>
                </div>
                <div class="col-12">
                    <label asp-for="TechSpecs" class="form-label"></label>
                    <textarea asp-for="TechSpecs" rows="3" class="form-control"></textarea>
                    <span asp-validation-for="TechSpecs" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Remark" class="form-label"></label>
                    <textarea asp-for="Remark" rows="2" class="form-control"></textarea>
                    <span asp-validation-for="Remark" class="text-danger small"></span>
                </div>
            </div>
        </fieldset>

        <fieldset class="mb-4">
            <legend class="fs-6 fw-semibold text-muted border-bottom pb-1 mb-3">设备图片</legend>

            @if (Model.ExistingImages.Any())
            {
                <div class="mb-3">
                    <div class="form-label small text-muted mb-2">现有图片（勾选后保存即永久删除）</div>
                    <div class="row g-2">
                        @foreach (var img in Model.ExistingImages)
                        {
                            <div class="col-6 col-md-3">
                                <div class="er-card p-2 h-100 text-center">
                                    <img src="/files/@img.FilePath.Replace('\\', '/')"
                                         class="img-fluid rounded"
                                         style="max-height:120px;object-fit:cover;width:100%"
                                         alt="设备图片" />
                                    <div class="form-check mt-2 d-inline-flex align-items-center gap-1">
                                        <input class="form-check-input" type="checkbox"
                                               name="DeleteImageIds" value="@img.Id"
                                               id="delImg_@img.Id" />
                                        <label class="form-check-label text-danger small mb-0"
                                               for="delImg_@img.Id">删除</label>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <label for="Images" class="er-dropzone d-flex flex-column align-items-center justify-content-center text-muted">
                <i class="bi bi-cloud-upload" style="font-size:2.25rem"></i>
                <div class="mt-2">点击选择图片或拖拽至此（上传新图片）</div>
                <div class="small">支持 .jpg / .jpeg / .png，可多选</div>
                <input id="Images" type="file" name="Images" multiple accept=".jpg,.jpeg,.png" class="d-none" />
            </label>
            <div id="Images-preview" class="row g-2 mt-2"></div>
        </fieldset>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-lg me-1"></i>保存修改
            </button>
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">取消</a>
        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        (function () {
            const input = document.getElementById('Images');
            const preview = document.getElementById('Images-preview');
            if (!input || !preview) return;
            input.addEventListener('change', () => {
                preview.innerHTML = '';
                Array.from(input.files || []).forEach(file => {
                    if (!file.type.startsWith('image/')) return;
                    const url = URL.createObjectURL(file);
                    const col = document.createElement('div');
                    col.className = 'col-6 col-md-3';
                    col.innerHTML = `
                        <div class="er-card p-2 h-100">
                            <img src="${url}" class="img-fluid rounded" style="max-height:120px;object-fit:cover;width:100%" alt="">
                            <div class="small text-truncate mt-1" title="${file.name}">${file.name}</div>
                        </div>`;
                    preview.appendChild(col);
                });
            });
        })();
    </script>
}
