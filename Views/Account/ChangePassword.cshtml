@model ChangePasswordViewModel
@{
    ViewData["Title"] = "修改密码";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">修改密码</h4>
    <a asp-action="Profile" class="btn btn-outline-secondary btn-sm">返回个人信息</a>
</div>

<div class="card" style="max-width: 440px;">
    <div class="card-body">
        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger py-2" })

        <form asp-action="ChangePassword" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="CurrentPassword" class="form-label"></label>
                <input asp-for="CurrentPassword" class="form-control" />
                <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label"></label>
                <input asp-for="NewPassword" class="form-control" />
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
                <div class="form-text">至少8位，包含大写字母、小写字母和数字</div>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <input asp-for="ConfirmPassword" class="form-control" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary">确认修改</button>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
