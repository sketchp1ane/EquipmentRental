@model LoginViewModel
@{
    ViewData["Title"] = "登录";
    Layout = "_AuthLayout";
}

<div class="text-center mb-4">
    <h4 class="fw-bold mb-1"><i class="bi bi-box-arrow-in-right text-primary me-2"></i>欢迎回来</h4>
    <p class="text-muted small mb-0">请使用您的账号登录继续</p>
</div>

@Html.ValidationSummary(true, "", new { @class = "alert alert-danger py-2 small" })

<form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label asp-for="Username" class="form-label er-required"></label>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-person"></i></span>
            <input asp-for="Username" class="form-control" autocomplete="username" autofocus
                   placeholder="请输入用户名" />
        </div>
        <span asp-validation-for="Username" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Password" class="form-label er-required"></label>
        <div class="input-group">
            <span class="input-group-text"><i class="bi bi-lock"></i></span>
            <input asp-for="Password" class="form-control" autocomplete="current-password"
                   placeholder="请输入密码" />
        </div>
        <span asp-validation-for="Password" class="text-danger small"></span>
    </div>

    <div class="mb-3 form-check">
        <input asp-for="RememberMe" class="form-check-input" />
        <label asp-for="RememberMe" class="form-check-label"></label>
    </div>

    <button type="submit" class="btn btn-primary w-100">
        <i class="bi bi-box-arrow-in-right me-1"></i>登录
    </button>
</form>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
}
