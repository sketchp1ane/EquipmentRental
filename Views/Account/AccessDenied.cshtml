@{
    ViewData["Title"] = "访问被拒绝";
    Layout = "_AuthLayout";
}

<div class="text-center">
    <div class="display-1 fw-bold text-danger mb-1"><i class="bi bi-shield-lock"></i></div>
    <div class="display-4 fw-bold text-danger mb-2">403</div>
    <h5 class="mb-2">权限不足</h5>
    <p class="text-muted mb-4">您没有权限访问该页面，请联系管理员。</p>
    <div class="d-flex gap-2 justify-content-center flex-wrap">
        <a href="/" class="btn btn-primary">
            <i class="bi bi-house me-1"></i>返回首页
        </a>
        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary">
            <i class="bi bi-box-arrow-in-right me-1"></i>切换账号
        </a>
    </div>
</div>
