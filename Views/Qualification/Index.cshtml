@model QualificationIndexViewModel
@{
    ViewData["Title"] = "证件管理";

    (string Key, string Text) EquipmentStatusVm(EquipmentStatus s) => s switch
    {
        EquipmentStatus.PendingReview => ("Pending",     "待审核"),
        EquipmentStatus.Idle          => ("Idle",        "闲置"),
        EquipmentStatus.InUse         => ("InUse",       "使用中"),
        EquipmentStatus.Maintenance   => ("Maintenance", "维修中"),
        EquipmentStatus.Scrapped      => ("Cancelled",   "已报废"),
        _                             => ("Draft",       s.ToString())
    };
    var (eKey, eText) = EquipmentStatusVm(Model.EquipmentStatus);
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <h4 class="mb-0"><i class="bi bi-file-earmark-text me-2"></i>证件管理</h4>
        <small class="text-muted d-inline-flex align-items-center gap-2 mt-1">
            <code>@Model.EquipmentNo</code> @Model.EquipmentName
            @await Html.PartialAsync("_StatusBadge", (Key: eKey, Text: eText))
        </small>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Create" asp-route-equipmentId="@Model.EquipmentId"
           class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>新增证件
        </a>
        <a asp-controller="Equipment" asp-action="Details" asp-route-id="@Model.EquipmentId"
           class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>返回设备详情
        </a>
    </div>
</div>

@if (Model.Items.Any())
{
    <div class="table-responsive">
        <table class="table table-hover table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th>证件类型</th>
                    <th>证件编号</th>
                    <th class="d-none d-lg-table-cell">发证机构</th>
                    <th class="d-none d-md-table-cell">有效期起</th>
                    <th>有效期至</th>
                    <th>状态</th>
                    <th>附件</th>
                    <th class="d-none d-xl-table-cell">更新时间</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.TypeName</td>
                        <td class="text-muted small">@(item.CertNo ?? "—")</td>
                        <td class="text-muted small d-none d-lg-table-cell text-truncate-2" style="max-width:180px">@(item.IssuedBy ?? "—")</td>
                        <td class="small d-none d-md-table-cell">@item.ValidFrom.ToDateStr()</td>
                        <td class="small">@item.ValidTo.ToDateStr()</td>
                        <td>
                            @if (item.IsExpired)
                            {
                                @await Html.PartialAsync("_StatusBadge", (Key: "Expired", Text: "已过期"))
                            }
                            else if (item.IsExpiringSoon)
                            {
                                @await Html.PartialAsync("_StatusBadge", (Key: "Expiring", Text: "即将到期"))
                            }
                            else
                            {
                                @await Html.PartialAsync("_StatusBadge", (Key: "Success", Text: "有效"))
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.FilePath))
                            {
                                <a href="/files/@item.FilePath.Replace('\\', '/')" target="_blank"
                                   class="btn btn-outline-secondary btn-sm" title="查看附件" data-bs-toggle="tooltip">
                                    <i class="bi bi-paperclip"></i>
                                </a>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td class="text-muted small d-none d-xl-table-cell">@item.UpdatedAt.ToDateTimeStr()</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id"
                               class="btn btn-outline-primary btn-sm" title="编辑" data-bs-toggle="tooltip">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="Delete" method="post" class="d-inline"
                                  data-er-confirm="确认删除该证件记录？删除后附件也将移除。"
                                  data-er-confirm-title="删除证件"
                                  data-er-confirm-ok="删除">
                                <input type="hidden" name="id" value="@item.Id" />
                                <input type="hidden" name="equipmentId" value="@Model.EquipmentId" />
                                <button type="submit" class="btn btn-outline-danger btn-sm" title="删除" data-bs-toggle="tooltip">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    @await Html.PartialAsync("_EmptyState", (
        Icon: "bi-file-earmark-text",
        Title: "暂无证件记录",
        Hint: "点击右上角「新增证件」上传首个证件",
        CtaText: "新增证件",
        CtaUrl: Url.Action("Create", new { equipmentId = Model.EquipmentId })
    ))
}
