@model InspectionDetailViewModel
@using EquipmentRental.Models
@using EquipmentRental.Models.ViewModels
@{
    ViewData["Title"] = $"巡检记录 #{Model.Id}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">巡检记录 <small class="text-muted fs-6">#@Model.Id</small></h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">返回列表</a>
</div>

<!-- 状态横幅 -->
@if (Model.OverallStatus == OverallInspectionStatus.Normal)
{
    <div class="alert alert-success py-2 mb-3">
        <strong>正常</strong> — 本次巡检未发现异常。
    </div>
}
else
{
    <div class="alert alert-warning py-2 mb-3">
        <strong>异常</strong> — 本次巡检发现异常，请关注处理情况。
    </div>
}

<div class="row g-4">
    <!-- 左列：基本信息 + 备注 + 照片 -->
    <div class="col-lg-8">
        <div class="card mb-3">
            <div class="card-header fw-semibold">基本信息</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3">调度单</dt>
                    <dd class="col-sm-9">
                        <a asp-controller="Dispatch" asp-action="OrderDetails" asp-route-id="@Model.OrderId">#@Model.OrderId</a>
                        &nbsp;@Model.ProjectName
                    </dd>
                    <dt class="col-sm-3">设备</dt>
                    <dd class="col-sm-9"><code>@Model.EquipmentNo</code> @Model.EquipmentName</dd>
                    <dt class="col-sm-3">巡检日期</dt>
                    <dd class="col-sm-9">@Model.InspectionDate.ToString("yyyy-MM-dd")</dd>
                    <dt class="col-sm-3">总体状态</dt>
                    <dd class="col-sm-9">
                        @if (Model.OverallStatus == OverallInspectionStatus.Normal)
                        {
                            <span class="badge bg-success">正常</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">异常</span>
                        }
                    </dd>
                    <dt class="col-sm-3">巡检员</dt>
                    <dd class="col-sm-9">@Model.InspectorName</dd>
                    <dt class="col-sm-3">记录时间</dt>
                    <dd class="col-sm-9">@Model.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</dd>
                </dl>
            </div>
        </div>

        @if (Model.ItemResults.Count > 0)
        {
            <div class="card mb-3">
                <div class="card-header fw-semibold">巡检项目</div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 40%">项目</th>
                                <th style="width: 20%">状态</th>
                                <th>备注</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model.ItemResults)
                            {
                                <tr>
                                    <td>@r.ItemName</td>
                                    <td>
                                        @switch (r.Status)
                                        {
                                            case InspectionItemStatus.Normal:
                                                <span class="badge bg-success">正常</span>
                                                break;
                                            case InspectionItemStatus.Abnormal:
                                                <span class="badge bg-warning text-dark">异常</span>
                                                break;
                                            case InspectionItemStatus.NotApplicable:
                                                <span class="badge bg-secondary">不适用</span>
                                                break;
                                        }
                                    </td>
                                    <td class="small text-muted">
                                        @(string.IsNullOrWhiteSpace(r.Remark) ? "—" : r.Remark)
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.Remark))
        {
            <div class="card mb-3">
                <div class="card-header fw-semibold">巡检备注</div>
                <div class="card-body">
                    <p class="mb-0" style="white-space:pre-wrap">@Model.Remark</p>
                </div>
            </div>
        }

        @if (Model.Images.Count > 0)
        {
            <div class="card mb-3">
                <div class="card-header fw-semibold">巡检照片</div>
                <div class="card-body">
                    <div class="row g-2">
                        @foreach (var img in Model.Images)
                        {
                            <div class="col-auto">
                                <a href="/files/@img.FilePath.Replace("\\", "/")" target="_blank">
                                    <img src="/files/@img.FilePath.Replace("\\", "/")"
                                         class="img-thumbnail" style="max-height:140px;max-width:180px;object-fit:cover"
                                         alt="巡检照片" />
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- 右列：调度单信息 -->
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header fw-semibold">关联调度单</div>
            <div class="card-body">
                <p class="mb-1">
                    <a asp-controller="Dispatch" asp-action="OrderDetails" asp-route-id="@Model.OrderId">
                        调度单 #@Model.OrderId
                    </a>
                </p>
                <p class="mb-1 small text-muted">@Model.ProjectName</p>
                <p class="mb-0 small"><code>@Model.EquipmentNo</code> @Model.EquipmentName</p>
            </div>
        </div>
    </div>
</div>
