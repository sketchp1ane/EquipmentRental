@model UtilizationViewModel
@{
    ViewData["Title"] = "设备利用率报表";
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h4 class="mb-0"><i class="bi bi-bar-chart-line me-2"></i>设备利用率报表</h4>
</div>

@await Html.PartialAsync("_DateRangeFilter", (From: Model.From, To: Model.To, FromName: "from", ToName: "to", SubmitText: "查询"))

@if (!Model.Stats.Categories.Any())
{
    @await Html.PartialAsync("_EmptyState", (
        Icon: "bi-bar-chart",
        Title: "暂无设备数据",
        Hint: "请调整日期范围或确认是否已录入设备数据",
        CtaText: (string?)null,
        CtaUrl: (string?)null
    ))
}
else
{
    <!-- 水平柱状图 -->
    <div class="er-card mb-4">
        <div class="card-header fw-semibold bg-transparent border-bottom">
            <i class="bi bi-bar-chart-steps me-2"></i>各分类利用率（%）
        </div>
        <div class="card-body">
            <div class="er-chart" style="height: clamp(240px, @(Math.Max(240, Model.Stats.Categories.Count() * 32))px, 520px)">
                <canvas id="utilizationChart"></canvas>
            </div>
        </div>
    </div>

    <script>
        (function () {
            var cats = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.Stats.Categories.Select(c => new { c.CategoryName, c.UtilizationRate })));
            var labels = cats.map(function(c){ return c.CategoryName; });
            var rates  = cats.map(function(c){ return c.UtilizationRate; });

            new Chart(document.getElementById('utilizationChart'), {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: '利用率 %',
                        data: rates,
                        backgroundColor: rates.map(function(r){
                            return r >= 80 ? 'rgba(220,38,38,0.75)'
                                 : r >= 50 ? 'rgba(245,158,11,0.75)'
                                 : 'rgba(22,163,74,0.75)';
                        })
                    }]
                },
                options: {
                    indexAxis: 'y',
                    maintainAspectRatio: false,
                    scales: {
                        x: { beginAtZero: true, max: 100,
                             ticks: { callback: function(v){ return v + '%'; } } }
                    },
                    plugins: { legend: { display: false } }
                }
            });
        })();
    </script>

    <!-- 数据表格 -->
    <div class="er-card">
        <div class="card-header fw-semibold bg-transparent border-bottom">
            <i class="bi bi-table me-2"></i>分类明细
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>设备分类</th>
                            <th class="text-end">设备数量</th>
                            <th class="text-end d-none d-md-table-cell">统计天数</th>
                            <th class="text-end d-none d-md-table-cell">占用天数</th>
                            <th class="text-end">利用率</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model.Stats.Categories)
                        {
                            var (bKey, bText) = c.UtilizationRate >= 80
                                ? ("Danger", $"{c.UtilizationRate} %")
                                : c.UtilizationRate >= 50
                                    ? ("Expiring", $"{c.UtilizationRate} %")
                                    : ("Success", $"{c.UtilizationRate} %");
                            <tr>
                                <td>@c.CategoryName</td>
                                <td class="text-end">@c.EquipmentCount</td>
                                <td class="text-end d-none d-md-table-cell">@c.TotalDays</td>
                                <td class="text-end d-none d-md-table-cell">@c.OccupiedDays</td>
                                <td class="text-end">
                                    @await Html.PartialAsync("_StatusBadge", (Key: bKey, Text: bText))
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
