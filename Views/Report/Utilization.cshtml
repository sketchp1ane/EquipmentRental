@model UtilizationViewModel
@{
    ViewData["Title"] = "设备利用率报表";
}

<h4 class="mb-3">设备利用率报表</h4>

<!-- 筛选表单 -->
<form method="get" class="row g-2 align-items-end mb-4">
    <div class="col-auto">
        <label class="form-label mb-1 small">开始日期</label>
        <input type="date" name="from" class="form-control form-control-sm"
               value="@Model.From.ToString("yyyy-MM-dd")" />
    </div>
    <div class="col-auto">
        <label class="form-label mb-1 small">结束日期</label>
        <input type="date" name="to" class="form-control form-control-sm"
               value="@Model.To.ToString("yyyy-MM-dd")" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary btn-sm">查询</button>
    </div>
</form>

@if (!Model.Stats.Categories.Any())
{
    <div class="alert alert-secondary">该时间段内暂无设备数据。</div>
}
else
{
    <!-- 水平柱状图 -->
    <div class="card mb-4">
        <div class="card-header fw-semibold">各分类利用率（%）</div>
        <div class="card-body">
            <canvas id="utilizationChart"></canvas>
        </div>
    </div>

    <script>
        (function () {
            var cats = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.Stats.Categories.Select(c => new { c.CategoryName, c.UtilizationRate })));
            var labels = cats.map(function(c){ return c.CategoryName; });
            var rates  = cats.map(function(c){ return c.UtilizationRate; });

            var canvas = document.getElementById('utilizationChart');
            canvas.height = Math.max(80, labels.length * 28);

            new Chart(canvas, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: '利用率 %',
                        data: rates,
                        backgroundColor: rates.map(function(r){
                            return r >= 80 ? 'rgba(220,53,69,0.75)'
                                 : r >= 50 ? 'rgba(255,193,7,0.75)'
                                 : 'rgba(25,135,84,0.75)';
                        })
                    }]
                },
                options: {
                    indexAxis: 'y',
                    scales: {
                        x: { beginAtZero: true, max: 100,
                             ticks: { callback: function(v){ return v + '%'; } } }
                    },
                    plugins: { legend: { display: false } }
                }
            });
        })();
    </script>

    <!-- 数据表格 -->
    <div class="card">
        <div class="card-header fw-semibold">分类明细</div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>设备分类</th>
                            <th class="text-end">设备数量</th>
                            <th class="text-end">统计天数</th>
                            <th class="text-end">占用天数</th>
                            <th class="text-end">利用率</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model.Stats.Categories)
                        {
                            var badgeCls = c.UtilizationRate >= 80 ? "bg-danger"
                                         : c.UtilizationRate >= 50 ? "bg-warning text-dark"
                                         : "bg-success";
                            <tr>
                                <td>@c.CategoryName</td>
                                <td class="text-end">@c.EquipmentCount</td>
                                <td class="text-end">@c.TotalDays</td>
                                <td class="text-end">@c.OccupiedDays</td>
                                <td class="text-end">
                                    <span class="badge @badgeCls">@c.UtilizationRate %</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
