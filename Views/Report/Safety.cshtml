@model SafetyReportViewModel
@{
    ViewData["Title"] = "安全记录报表";
    bool hasData = Model.Stats.BriefingStatus.Any()
                || Model.Stats.InspectionStatus.Any()
                || Model.Stats.FaultSeverity.Any()
                || Model.Stats.FaultStatus.Any();
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h4 class="mb-0"><i class="bi bi-shield-check me-2"></i>安全记录报表</h4>
</div>

@await Html.PartialAsync("_DateRangeFilter", (From: Model.From, To: Model.To, FromName: "from", ToName: "to", SubmitText: "查询"))

@if (!hasData)
{
    @await Html.PartialAsync("_EmptyState", (
        Icon: "bi-shield-check",
        Title: "暂无安全记录数据",
        Hint: "请调整日期范围或确认是否已生成相关记录",
        CtaText: (string?)null,
        CtaUrl: (string?)null
    ))
}
else
{
    <div class="row g-4">
        <div class="col-12 col-md-6">
            <div class="er-card h-100">
                <div class="card-header fw-semibold bg-transparent border-bottom">
                    <i class="bi bi-journal-text me-2"></i>安全交底状态分布
                </div>
                <div class="card-body">
                    @if (Model.Stats.BriefingStatus.Any())
                    {
                        <div class="er-chart"><canvas id="briefingChart"></canvas></div>
                    }
                    else
                    {
                        <p class="text-muted text-center my-4">暂无数据</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6">
            <div class="er-card h-100">
                <div class="card-header fw-semibold bg-transparent border-bottom">
                    <i class="bi bi-clipboard-check me-2"></i>巡检记录状态分布
                </div>
                <div class="card-body">
                    @if (Model.Stats.InspectionStatus.Any())
                    {
                        <div class="er-chart"><canvas id="inspectionChart"></canvas></div>
                    }
                    else
                    {
                        <p class="text-muted text-center my-4">暂无数据</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6">
            <div class="er-card h-100">
                <div class="card-header fw-semibold bg-transparent border-bottom">
                    <i class="bi bi-exclamation-triangle me-2"></i>故障报告严重程度分布
                </div>
                <div class="card-body">
                    @if (Model.Stats.FaultSeverity.Any())
                    {
                        <div class="er-chart"><canvas id="faultSeverityChart"></canvas></div>
                    }
                    else
                    {
                        <p class="text-muted text-center my-4">暂无数据</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6">
            <div class="er-card h-100">
                <div class="card-header fw-semibold bg-transparent border-bottom">
                    <i class="bi bi-wrench me-2"></i>故障报告处理状态分布
                </div>
                <div class="card-body">
                    @if (Model.Stats.FaultStatus.Any())
                    {
                        <div class="er-chart"><canvas id="faultStatusChart"></canvas></div>
                    }
                    else
                    {
                        <p class="text-muted text-center my-4">暂无数据</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <script>
        (function () {
            var COLORS = [
                'rgba(30,94,255,0.8)',
                'rgba(22,163,74,0.8)',
                'rgba(220,38,38,0.8)',
                'rgba(245,158,11,0.8)',
                'rgba(14,165,233,0.8)',
                'rgba(107,114,128,0.8)'
            ];

            function makePie(id, data) {
                var el = document.getElementById(id);
                if (!el || !data) return;
                var keys = Object.keys(data);
                var vals = keys.map(function(k){ return data[k]; });
                new Chart(el, {
                    type: 'pie',
                    data: {
                        labels: keys,
                        datasets: [{ data: vals, backgroundColor: COLORS.slice(0, keys.length) }]
                    },
                    options: {
                        maintainAspectRatio: false,
                        plugins: { legend: { position: 'bottom' } }
                    }
                });
            }

            var stats = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Stats));
            makePie('briefingChart',      stats.BriefingStatus);
            makePie('inspectionChart',    stats.InspectionStatus);
            makePie('faultSeverityChart', stats.FaultSeverity);
            makePie('faultStatusChart',   stats.FaultStatus);
        })();
    </script>
}
