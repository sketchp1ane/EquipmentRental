@model RentalReportViewModel
@{
    ViewData["Title"] = "租赁统计报表";
    bool hasData = Model.Stats.Total > 0;
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h4 class="mb-0"><i class="bi bi-cash-coin me-2"></i>租赁统计报表</h4>
    @if (hasData)
    {
        <a asp-action="ExportRentalExcel"
           asp-route-from="@Model.From.ToString("yyyy-MM-dd")"
           asp-route-to="@Model.To.ToString("yyyy-MM-dd")"
           class="btn btn-success btn-sm">
            <i class="bi bi-file-earmark-excel me-1"></i>导出 Excel
        </a>
    }
    else
    {
        <button type="button" class="btn btn-success btn-sm disabled" aria-disabled="true"
                data-bs-toggle="tooltip" title="当前时间段无数据可导出">
            <i class="bi bi-file-earmark-excel me-1"></i>导出 Excel
        </button>
    }
</div>

@await Html.PartialAsync("_DateRangeFilter", (From: Model.From, To: Model.To, FromName: "from", ToName: "to", SubmitText: "查询"))

@if (!hasData)
{
    @await Html.PartialAsync("_EmptyState", (
        Icon: "bi-cash-coin",
        Title: "暂无租赁订单数据",
        Hint: "请调整日期范围或确认是否已创建订单",
        CtaText: (string?)null,
        CtaUrl: (string?)null
    ))
}
else
{
    <!-- 汇总卡片 -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="er-stat-card text-bg-primary h-100">
                <div class="card-body py-3">
                    <div class="stat-value">@Model.Stats.Total</div>
                    <div class="stat-label">总订单数</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="er-stat-card text-bg-success h-100">
                <div class="card-body py-3">
                    <div class="stat-value">@Model.Stats.Completed</div>
                    <div class="stat-label">已完成</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="er-stat-card text-bg-info h-100">
                <div class="card-body py-3">
                    <div class="stat-value">@Model.Stats.InProgress</div>
                    <div class="stat-label">租赁中</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="er-stat-card text-bg-secondary h-100">
                <div class="card-body py-3">
                    <div class="stat-value">@Model.Stats.Terminated</div>
                    <div class="stat-label">已终止</div>
                </div>
            </div>
        </div>
    </div>

    <!-- 按月柱状图 -->
    @if (Model.Stats.Monthly.Count > 0)
    {
        <div class="er-card mb-4">
            <div class="card-header fw-semibold bg-transparent border-bottom">
                <i class="bi bi-calendar3 me-2"></i>按月订单量
            </div>
            <div class="card-body">
                <div class="er-chart">
                    <canvas id="rentalMonthlyChart"></canvas>
                </div>
            </div>
        </div>

        <script>
            (function () {
                var monthly = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Stats.Monthly));
                new Chart(document.getElementById('rentalMonthlyChart'), {
                    type: 'bar',
                    data: {
                        labels: monthly.map(function(d){ return d.Month; }),
                        datasets: [{
                            label: '订单数',
                            data: monthly.map(function(d){ return d.Count; }),
                            backgroundColor: 'rgba(30,94,255,0.75)'
                        }]
                    },
                    options: {
                        maintainAspectRatio: false,
                        scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } },
                        plugins: { legend: { display: false } }
                    }
                });
            })();
        </script>
    }

    <!-- 明细表格 -->
    <div class="er-card">
        <div class="card-header fw-semibold bg-transparent border-bottom">
            <i class="bi bi-list-ul me-2"></i>明细列表
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>项目名称</th>
                            <th>设备名称</th>
                            <th class="d-none d-md-table-cell">开始日期</th>
                            <th class="d-none d-md-table-cell">结束日期</th>
                            <th class="text-end">租期(天)</th>
                            <th class="text-end">估算收入(元)</th>
                            <th>状态</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model.Stats.Details)
                        {
                            int days = Math.Max(0, d.ActualEnd.DayNumber - d.ActualStart.DayNumber);
                            <tr>
                                <td class="text-truncate-2" style="max-width:200px">@d.ProjectName</td>
                                <td class="text-truncate-2" style="max-width:200px">@d.EquipmentName</td>
                                <td class="d-none d-md-table-cell small">@d.ActualStart.ToString("yyyy-MM-dd")</td>
                                <td class="d-none d-md-table-cell small">@d.ActualEnd.ToString("yyyy-MM-dd")</td>
                                <td class="text-end">@days</td>
                                <td class="text-end">@d.EstimatedRevenue.ToString("N2")</td>
                                <td>
                                    @await Html.PartialAsync("_StatusBadge", (Key: "Info", Text: d.Status))
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
