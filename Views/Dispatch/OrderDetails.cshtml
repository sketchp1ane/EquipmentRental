@model OrderDetailViewModel
@using EquipmentRental.Models
@using EquipmentRental.Models.ViewModels
@{
    ViewData["Title"] = $"调度单 #{Model.OrderId}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">调度单详情 <small class="text-muted fs-6">#@Model.OrderId</small></h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">返回列表</a>
</div>

<div class="row g-4">
    <!-- 左侧：调度单信息 -->
    <div class="col-lg-8">
        <div class="card mb-3">
            <div class="card-header fw-semibold">项目与联系信息</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">项目名称</dt>
                    <dd class="col-sm-8">@Model.ProjectName</dd>
                    <dt class="col-sm-4">项目地址</dt>
                    <dd class="col-sm-8">@Model.ProjectAddress</dd>
                    <dt class="col-sm-4">联系人</dt>
                    <dd class="col-sm-8">@Model.ContactName &nbsp; @Model.ContactPhone</dd>
                </dl>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header fw-semibold">设备信息</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">设备编号</dt>
                    <dd class="col-sm-8"><code>@Model.EquipmentNo</code></dd>
                    <dt class="col-sm-4">设备名称</dt>
                    <dd class="col-sm-8">@Model.EquipmentName</dd>
                    <dt class="col-sm-4">品牌型号</dt>
                    <dd class="col-sm-8">@Model.BrandModel</dd>
                </dl>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header fw-semibold">租期与费用</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">租赁开始</dt>
                    <dd class="col-sm-8">@Model.ActualStart.ToString("yyyy-MM-dd")</dd>
                    <dt class="col-sm-4">租赁结束</dt>
                    <dd class="col-sm-8">@Model.ActualEnd.ToString("yyyy-MM-dd")</dd>
                    <dt class="col-sm-4">天数</dt>
                    <dd class="col-sm-8">@((Model.ActualEnd.DayNumber - Model.ActualStart.DayNumber + 1)) 天</dd>
                    <dt class="col-sm-4">日租金</dt>
                    <dd class="col-sm-8">¥ @Model.UnitPrice.ToString("N2") / 天</dd>
                    <dt class="col-sm-4">租赁金额</dt>
                    <dd class="col-sm-8"><strong>¥ @Model.RentalAmount.ToString("N2")</strong></dd>
                    <dt class="col-sm-4">押金</dt>
                    <dd class="col-sm-8">¥ @Model.Deposit.ToString("N2")</dd>
                    <dt class="col-sm-4">调度员</dt>
                    <dd class="col-sm-8">@Model.DispatcherName</dd>
                    <dt class="col-sm-4">创建时间</dt>
                    <dd class="col-sm-8">@Model.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</dd>
                </dl>
            </div>
        </div>

        <!-- 合同状态 -->
        @if (Model.ContractId.HasValue)
        {
            <div class="card">
                <div class="card-header fw-semibold">关联合同</div>
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <div>合同编号：<code>@Model.ContractNo</code></div>
                        <div class="mt-1">
                            @switch (Model.ContractStatus)
                            {
                                case ContractStatus.Draft:
                                    <span class="badge bg-secondary">草稿</span>
                                    break;
                                case ContractStatus.AwaitingSignature:
                                    <span class="badge bg-warning text-dark">待签署</span>
                                    break;
                                case ContractStatus.Signed:
                                    <span class="badge bg-success">已签署</span>
                                    break;
                                case ContractStatus.Terminated:
                                    <span class="badge bg-danger">已终止</span>
                                    break;
                            }
                        </div>
                    </div>
                    <a asp-controller="Contract" asp-action="Details" asp-route-id="@Model.ContractId"
                       class="btn btn-outline-primary btn-sm">查看合同</a>
                </div>
            </div>
        }
    </div>

    <!-- 右侧：调度单状态 + 核验码 -->
    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-header fw-semibold">调度单状态</div>
            <div class="card-body text-center py-4">
                @switch (Model.OrderStatus)
                {
                    case DispatchOrderStatus.Unsigned:
                        <span class="badge bg-warning text-dark fs-6 px-3 py-2">待签署</span>
                        break;
                    case DispatchOrderStatus.Signed:
                        <span class="badge bg-info fs-6 px-3 py-2">已签署</span>
                        break;
                    case DispatchOrderStatus.InProgress:
                        <span class="badge bg-success fs-6 px-3 py-2">进行中</span>
                        break;
                    case DispatchOrderStatus.Complete:
                        <span class="badge bg-secondary fs-6 px-3 py-2">已完成</span>
                        break;
                    case DispatchOrderStatus.Terminated:
                        <span class="badge bg-danger fs-6 px-3 py-2">已终止</span>
                        break;
                }
            </div>
        </div>

        @if (Model.OrderStatus == DispatchOrderStatus.InProgress || Model.OrderStatus == DispatchOrderStatus.Complete)
        {
            <div class="card mb-3">
                <div class="card-header fw-semibold">安全交底</div>
                <div class="card-body text-center">
                    <p class="text-muted small mb-2">设备进场后，安全员可为本调度单创建安全交底记录。</p>
                    <a asp-controller="Safety" asp-action="Create" asp-route-orderId="@Model.OrderId"
                       class="btn btn-sm btn-warning">新建交底</a>
                    <a asp-controller="Safety" asp-action="List"
                       class="btn btn-sm btn-outline-secondary ms-1">查看交底列表</a>
                </div>
            </div>
        }

        @if (Model.OrderStatus >= DispatchOrderStatus.Signed)
        {
            <div class="card">
                <div class="card-header fw-semibold">进场核验码</div>
                <div class="card-body text-center">
                    <p class="text-muted small mb-2">进场时扫描或输入以下核验码</p>
                    @if (!string.IsNullOrEmpty(Model.QrCodeDataUri))
                    {
                        <img src="@Model.QrCodeDataUri" alt="核验码二维码" class="img-fluid mb-2" style="max-width:160px;" />
                    }
                    <div class="mt-2 mb-3">
                        <code class="user-select-all fs-6">@Model.VerifyCode</code>
                    </div>
                    @if (Model.IsVerified)
                    {
                        <span class="badge bg-success">已核验</span>
                    }
                    else if (Model.OrderStatus == DispatchOrderStatus.Signed)
                    {
                        <a asp-controller="Verification" asp-action="Verify"
                           asp-route-code="@Model.VerifyCode"
                           class="btn btn-sm btn-primary">前往核验</a>
                    }
                </div>
            </div>
        }
    </div>
</div>
