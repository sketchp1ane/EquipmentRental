@model DispatchOrderListViewModel
@using EquipmentRental.Models
@using EquipmentRental.Models.ViewModels
@{
    ViewData["Title"] = "调度单列表";

    (string Key, string Text) OrderStatusVm(DispatchOrderStatus s) => s switch
    {
        DispatchOrderStatus.Unsigned   => ("Pending",   "待签署"),
        DispatchOrderStatus.Signed     => ("Info",      "已签署"),
        DispatchOrderStatus.InProgress => ("Success",   "进行中"),
        DispatchOrderStatus.Complete   => ("Draft",     "已完成"),
        DispatchOrderStatus.Terminated => ("Cancelled", "已终止"),
        _                              => ("Draft",     s.ToString())
    };

    (string Key, string Text) ContractStatusVm(ContractStatus s) => s switch
    {
        ContractStatus.Draft             => ("Draft",      "合同·草稿"),
        ContractStatus.AwaitingSignature => ("Pending",    "合同·待签署"),
        ContractStatus.Signed            => ("Success",    "合同·已签署"),
        ContractStatus.Terminated        => ("Cancelled",  "合同·已终止"),
        _                                => ("Draft",      s.ToString())
    };
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h4 class="mb-0"><i class="bi bi-truck me-2"></i>调度单列表</h4>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-clipboard-check me-1"></i>用车申请
        </a>
        <a asp-action="Calendar" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-calendar3 me-1"></i>调度日历
        </a>
    </div>
</div>

<!-- 状态筛选 -->
<ul class="nav nav-pills mb-3 flex-wrap">
    <li class="nav-item">
        <a class="nav-link @(Model.StatusFilter == null ? "active" : "")"
           asp-action="Orders" asp-route-keyword="@Model.Keyword">全部</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(Model.StatusFilter == DispatchOrderStatus.Unsigned ? "active" : "")"
           asp-action="Orders" asp-route-status="@DispatchOrderStatus.Unsigned"
           asp-route-keyword="@Model.Keyword">待签署</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(Model.StatusFilter == DispatchOrderStatus.Signed ? "active" : "")"
           asp-action="Orders" asp-route-status="@DispatchOrderStatus.Signed"
           asp-route-keyword="@Model.Keyword">已签署</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(Model.StatusFilter == DispatchOrderStatus.InProgress ? "active" : "")"
           asp-action="Orders" asp-route-status="@DispatchOrderStatus.InProgress"
           asp-route-keyword="@Model.Keyword">进行中</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(Model.StatusFilter == DispatchOrderStatus.Complete ? "active" : "")"
           asp-action="Orders" asp-route-status="@DispatchOrderStatus.Complete"
           asp-route-keyword="@Model.Keyword">已完成</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(Model.StatusFilter == DispatchOrderStatus.Terminated ? "active" : "")"
           asp-action="Orders" asp-route-status="@DispatchOrderStatus.Terminated"
           asp-route-keyword="@Model.Keyword">已终止</a>
    </li>
</ul>

<!-- 关键字搜索 -->
<form asp-action="Orders" method="get" class="row g-2 mb-3">
    <input type="hidden" name="status" value="@Model.StatusFilter" />
    <div class="col-auto">
        <input type="text" name="keyword" value="@Model.Keyword" class="form-control form-control-sm"
               placeholder="项目名 / 设备编号 / 合同号" style="min-width: 260px;" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary btn-sm">
            <i class="bi bi-search me-1"></i>搜索
        </button>
        @if (!string.IsNullOrWhiteSpace(Model.Keyword))
        {
            <a asp-action="Orders" asp-route-status="@Model.StatusFilter"
               class="btn btn-outline-secondary btn-sm">清除</a>
        }
    </div>
</form>

@if (Model.Items.Any())
{
    <div class="table-responsive">
        <table class="table table-hover table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th>项目名称</th>
                    <th>设备</th>
                    <th class="text-nowrap">租期</th>
                    <th class="d-none d-md-table-cell">日租金</th>
                    <th class="d-none d-lg-table-cell">合同</th>
                    <th class="d-none d-xl-table-cell">调度员</th>
                    <th class="d-none d-xl-table-cell">创建时间</th>
                    <th>状态</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td class="text-truncate-2" style="max-width:200px">@item.ProjectName</td>
                        <td class="small">
                            <div><code>@item.EquipmentNo</code></div>
                            <div class="text-muted text-truncate-2" style="max-width:180px">@item.EquipmentName</div>
                        </td>
                        <td class="text-muted small text-nowrap">
                            @DateFormatExtensions.ToDateRangeStr(item.ActualStart, item.ActualEnd)
                        </td>
                        <td class="text-nowrap d-none d-md-table-cell">¥ @item.UnitPrice.ToString("N2")</td>
                        <td class="small d-none d-lg-table-cell">
                            @if (!string.IsNullOrEmpty(item.ContractNo))
                            {
                                <div class="text-muted"><i class="bi bi-file-earmark-text me-1"></i>@item.ContractNo</div>
                                if (item.ContractStatus.HasValue)
                                {
                                    var (ck, ct) = ContractStatusVm(item.ContractStatus.Value);
                                    @await Html.PartialAsync("_StatusBadge", (Key: ck, Text: ct))
                                }
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="text-muted small d-none d-xl-table-cell">@item.DispatcherName</td>
                        <td class="text-muted small text-nowrap d-none d-xl-table-cell">@item.CreatedAt.ToLocalTime().ToDateStr()</td>
                        <td>
                            @{ var (k, t) = OrderStatusVm(item.Status); }
                            @await Html.PartialAsync("_StatusBadge", (Key: k, Text: t))
                        </td>
                        <td>
                            <a asp-action="OrderDetails" asp-route-id="@item.Id"
                               class="btn btn-outline-secondary btn-sm" title="查看详情" data-bs-toggle="tooltip">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    @await Html.PartialAsync("_EmptyState", (
        Icon: "bi-truck",
        Title: "暂无调度单",
        Hint: "筛选条件下无匹配调度单",
        CtaText: (string?)null,
        CtaUrl: (string?)null
    ))
}

@await Html.PartialAsync("_Pagination", new PaginationViewModel
{
    Page = Model.Page,
    TotalPages = Model.TotalPages,
    TotalCount = Model.TotalCount,
    ActionName = "Orders",
    RouteValues = new Dictionary<string, string?>
    {
        ["status"]  = Model.StatusFilter?.ToString(),
        ["keyword"] = Model.Keyword
    }
})
