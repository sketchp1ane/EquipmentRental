@model SafetyListViewModel
@using EquipmentRental.Models
@using EquipmentRental.Models.ViewModels
@{
    ViewData["Title"] = "安全交底记录";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">安全交底记录</h4>
</div>

@if (Model.Items.Count == 0)
{
    <div class="text-center py-5 text-muted">暂无安全交底记录</div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>调度单</th>
                        <th>项目名称</th>
                        <th>交底日期</th>
                        <th>交底地点</th>
                        <th>安全员</th>
                        <th>状态</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>#@item.Id</td>
                            <td>
                                <a asp-controller="Dispatch" asp-action="OrderDetails" asp-route-id="@item.OrderId">#@item.OrderId</a>
                            </td>
                            <td>@item.ProjectName</td>
                            <td>@item.BriefingDate.ToString("yyyy-MM-dd")</td>
                            <td>@item.Location</td>
                            <td>@item.CreatorName</td>
                            <td>
                                @if (item.Status == SafetyBriefingStatus.Completed)
                                {
                                    <span class="badge bg-success">已完成</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">草稿</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-outline-secondary btn-sm">详情</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination pagination-sm justify-content-center">
                @for (int p = 1; p <= Model.TotalPages; p++)
                {
                    <li class="page-item @(p == Model.Page ? "active" : "")">
                        <a class="page-link" asp-action="List" asp-route-page="@p">@p</a>
                    </li>
                }
            </ul>
        </nav>
    }

    <div class="text-muted small text-end mt-2">共 @Model.TotalCount 条记录</div>
}
