@model SafetyListViewModel
@using EquipmentRental.Models
@using EquipmentRental.Models.ViewModels
@using EquipmentRental.Constants
@{
    ViewData["Title"] = "安全交底记录";
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h4 class="mb-0"><i class="bi bi-shield-exclamation me-2"></i>安全交底记录</h4>
    @if (User.IsInRole(Roles.SafetyOfficer) || User.IsInRole(Roles.Admin))
    {
        <a asp-action="SelectOrder" class="btn btn-warning btn-sm">
            <i class="bi bi-plus-lg me-1"></i>新建交底
        </a>
    }
</div>

<!-- 状态过滤 -->
<ul class="nav nav-pills mb-3 flex-wrap">
    <li class="nav-item">
        <a class="nav-link @(Model.StatusFilter == null ? "active" : "")"
           asp-action="List">全部</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(Model.StatusFilter == SafetyBriefingStatus.Draft ? "active" : "")"
           asp-action="List" asp-route-status="@SafetyBriefingStatus.Draft">待签署</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(Model.StatusFilter == SafetyBriefingStatus.Completed ? "active" : "")"
           asp-action="List" asp-route-status="@SafetyBriefingStatus.Completed">已完成</a>
    </li>
</ul>

@if (Model.Items.Any())
{
    <div class="table-responsive">
        <table class="table table-hover table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>调度单</th>
                    <th class="d-none d-md-table-cell">项目名称</th>
                    <th>交底日期</th>
                    <th class="d-none d-lg-table-cell">交底地点</th>
                    <th class="d-none d-xl-table-cell">安全员</th>
                    <th>状态</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td class="text-muted small">#@item.Id</td>
                        <td>
                            <a asp-controller="Dispatch" asp-action="OrderDetails" asp-route-id="@item.OrderId"
                               class="text-decoration-none">#@item.OrderId</a>
                        </td>
                        <td class="text-truncate-2 d-none d-md-table-cell" style="max-width:200px">@item.ProjectName</td>
                        <td class="text-nowrap">@item.BriefingDate.ToDateStr()</td>
                        <td class="text-muted small d-none d-lg-table-cell text-truncate-2" style="max-width:180px">@item.Location</td>
                        <td class="text-muted small d-none d-xl-table-cell">@item.CreatorName</td>
                        <td>
                            @if (item.Status == SafetyBriefingStatus.Completed)
                            {
                                @await Html.PartialAsync("_StatusBadge", (Key: "Success", Text: "双方已签"))
                            }
                            else
                            {
                                @await Html.PartialAsync("_StatusBadge", (Key: "Pending", Text: "待签署"))
                            }
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id"
                               class="btn btn-outline-secondary btn-sm" title="详情" data-bs-toggle="tooltip">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    @await Html.PartialAsync("_EmptyState", (
        Icon: "bi-shield-exclamation",
        Title: "暂无安全交底记录",
        Hint: "筛选条件下无匹配记录",
        CtaText: (string?)null,
        CtaUrl: (string?)null
    ))
}

@await Html.PartialAsync("_Pagination", new PaginationViewModel
{
    Page = Model.Page,
    TotalPages = Model.TotalPages,
    TotalCount = Model.TotalCount,
    ActionName = "List",
    RouteValues = new Dictionary<string, string?>
    {
        ["status"] = Model.StatusFilter?.ToString()
    }
})
