@model SelectOrderViewModel
@using EquipmentRental.Models.ViewModels
@{
    ViewData["Title"] = "选择调度单";
}

<!-- 面包屑 -->
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="List">安全交底记录</a></li>
        <li class="breadcrumb-item active">选择调度单</li>
    </ol>
</nav>

<!-- 步骤条 -->
<div class="d-flex align-items-center mb-4 px-1">
    <div class="d-flex align-items-center">
        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white bg-warning" style="width:2rem;height:2rem;font-size:.85rem">1</div>
        <span class="ms-2 fw-semibold text-warning">选择调度单</span>
    </div>
    <div class="flex-grow-1 border-top border-2 mx-3" style="max-width:5rem"></div>
    <div class="d-flex align-items-center text-muted">
        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold bg-light border" style="width:2rem;height:2rem;font-size:.85rem">2</div>
        <span class="ms-2">填写安全交底</span>
    </div>
    <div class="flex-grow-1 border-top border-2 mx-3" style="max-width:5rem"></div>
    <div class="d-flex align-items-center text-muted">
        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold bg-light border" style="width:2rem;height:2rem;font-size:.85rem">3</div>
        <span class="ms-2">提交确认</span>
    </div>
</div>

<p class="text-muted mb-4">以下为已完成进场核验、当前进行中的调度单，选择后新建安全交底。</p>

@if (Model.Orders.Count == 0)
{
    <div class="text-center py-5">
        <div class="text-muted mb-3" style="font-size:3rem">&#128274;</div>
        <p class="fw-semibold mb-1">暂无可用的调度单</p>
        <p class="text-muted small mb-3">需要调度单处于<strong>进行中</strong>状态且已完成进场核验后才可新建安全交底。</p>
        <a asp-controller="Dispatch" asp-action="Index" class="btn btn-outline-primary btn-sm">前往调度管理</a>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
        @foreach (var o in Model.Orders)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-header d-flex align-items-center justify-content-between py-2">
                        <span class="badge bg-secondary">#@o.OrderId</span>
                        <span class="badge bg-success text-white">进行中</span>
                    </div>
                    <div class="card-body">
                        <h6 class="card-title mb-3">@o.ProjectName</h6>
                        <dl class="row mb-0 small text-muted">
                            <dt class="col-5">设备编号</dt>
                            <dd class="col-7"><code>@o.EquipmentNo</code></dd>
                            <dt class="col-5">设备名称</dt>
                            <dd class="col-7">@o.EquipmentName</dd>
                            <dt class="col-5">租赁期间</dt>
                            <dd class="col-7 text-nowrap">@o.ActualStart.ToString("MM-dd") 至 @o.ActualEnd.ToString("MM-dd")</dd>
                        </dl>
                    </div>
                    <div class="card-footer bg-transparent d-flex justify-content-end">
                        <a asp-action="Create" asp-route-orderId="@o.OrderId"
                           class="btn btn-warning btn-sm">新建交底 &rarr;</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
