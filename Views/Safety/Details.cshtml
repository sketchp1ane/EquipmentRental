@model SafetyDetailViewModel
@using EquipmentRental.Models
@using EquipmentRental.Models.ViewModels
@{
    ViewData["Title"] = $"安全交底 #{Model.Id}";
    bool isDraft = Model.Status == SafetyBriefingStatus.Draft;
    bool canSignAsSO = Model.CanSign && (User.IsInRole(EquipmentRental.Constants.Roles.SafetyOfficer) || User.IsInRole(EquipmentRental.Constants.Roles.Admin));
    bool canSignAsPL = Model.CanSign && (User.IsInRole(EquipmentRental.Constants.Roles.ProjectLead) || User.IsInRole(EquipmentRental.Constants.Roles.Admin));
    bool needsMyAction = isDraft && ((canSignAsSO && !Model.SafetyOfficerSigned) || (canSignAsPL && !Model.ProjectLeadSigned));
}

<style>
    .sign-card { border-radius: .5rem; }
    .sign-card .sign-icon { font-size: 1.6rem; }
</style>

<!-- 面包屑 + 操作 -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-action="List">安全交底记录</a></li>
            <li class="breadcrumb-item active">交底 #@Model.Id</li>
        </ol>
    </nav>
    <div class="d-flex gap-2">
        <a asp-action="ExportPdf" asp-route-id="@Model.Id"
           class="btn btn-outline-secondary btn-sm" target="_blank">&#128196; 导出 PDF</a>
        <a asp-action="List" class="btn btn-outline-secondary btn-sm">返回列表</a>
    </div>
</div>

<!-- 流程进度指示器 -->
<div class="d-flex align-items-center mb-4 gap-0">
    <span class="badge rounded-pill bg-success px-3 py-2">&#10003; 已创建</span>
    <div class="flex-grow-0" style="width:2rem;height:2px;background:#dee2e6"></div>
    @if (isDraft)
    {
        <span class="badge rounded-pill bg-warning text-dark px-3 py-2 fw-semibold">&#9998; 待签署</span>
        <div class="flex-grow-0" style="width:2rem;height:2px;background:#dee2e6"></div>
        <span class="badge rounded-pill bg-light text-muted border px-3 py-2">已完成</span>
    }
    else
    {
        <span class="badge rounded-pill bg-light text-muted border px-3 py-2">待签署</span>
        <div class="flex-grow-0" style="width:2rem;height:2px;background:#dee2e6"></div>
        <span class="badge rounded-pill bg-success px-3 py-2 fw-semibold">&#10003; 已完成</span>
    }
</div>

<!-- 当前用户需要签署时的提示横幅 -->
@if (needsMyAction)
{
    <div class="alert alert-warning d-flex align-items-center gap-2 mb-4 py-2">
        <span style="font-size:1.2rem">&#9888;</span>
        <span>等待您的签署确认，请在右侧签署区完成操作。</span>
    </div>
}

@if (!isDraft)
{
    <div class="alert alert-success d-flex align-items-center gap-2 mb-4 py-2">
        <span style="font-size:1.2rem">&#10003;</span>
        <span>安全交底已由双方签署确认，记录已锁定。</span>
    </div>
}

<div class="row g-4">
    <!-- 左列：基本信息 + 内容 + 参与人 + 附件 -->
    <div class="col-lg-8">

        <div class="card mb-3">
            <div class="card-header fw-semibold border-start border-3 border-primary ps-3">基本信息</div>
            <div class="card-body">
                <dl class="row mb-0 small">
                    <dt class="col-sm-3 text-muted">调度单</dt>
                    <dd class="col-sm-9">
                        <a asp-controller="Dispatch" asp-action="OrderDetails" asp-route-id="@Model.OrderId">#@Model.OrderId</a>
                        &nbsp;@Model.ProjectName
                    </dd>
                    <dt class="col-sm-3 text-muted">设备</dt>
                    <dd class="col-sm-9"><code>@Model.EquipmentNo</code> @Model.EquipmentName</dd>
                    <dt class="col-sm-3 text-muted">交底日期</dt>
                    <dd class="col-sm-9">@Model.BriefingDate.ToString("yyyy-MM-dd")</dd>
                    <dt class="col-sm-3 text-muted">交底地点</dt>
                    <dd class="col-sm-9">@Model.Location</dd>
                    <dt class="col-sm-3 text-muted">安全员</dt>
                    <dd class="col-sm-9">@Model.CreatorName</dd>
                    <dt class="col-sm-3 text-muted">创建时间</dt>
                    <dd class="col-sm-9">@Model.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</dd>
                </dl>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header fw-semibold border-start border-3 border-primary ps-3">交底内容</div>
            <div class="card-body briefing-content">
                @Html.Raw(Model.ContentHtml)
            </div>
        </div>

        @if (Model.Workers.Count > 0)
        {
            <div class="card mb-3">
                <div class="card-header fw-semibold border-start border-3 border-primary ps-3">
                    参与人员 <span class="badge bg-secondary ms-1">@Model.Workers.Count 人</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm table-striped mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>姓名</th>
                                <th>工种</th>
                                <th>联系电话</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var w in Model.Workers)
                            {
                                <tr>
                                    <td>@w.Name</td>
                                    <td>@w.JobType</td>
                                    <td class="text-muted">@(w.Phone ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @if (Model.Attachments.Count > 0)
        {
            <div class="card mb-3">
                <div class="card-header fw-semibold border-start border-3 border-primary ps-3">附件</div>
                <ul class="list-group list-group-flush">
                    @foreach (var att in Model.Attachments)
                    {
                        var ext = System.IO.Path.GetExtension(att.OriginalName).ToLower();
                        var icon = ext == ".pdf" ? "&#128196;" : "&#128444;";
                        <li class="list-group-item d-flex align-items-center gap-2 py-2">
                            <span>@Html.Raw(icon)</span>
                            <a href="/files/@att.FilePath.Replace("\\","/")" target="_blank" class="text-truncate">@att.OriginalName</a>
                        </li>
                    }
                </ul>
            </div>
        }

    </div>

    <!-- 右列：电子签署 -->
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header fw-semibold border-start border-3 border-warning ps-3">电子签署</div>
            <div class="card-body d-flex flex-column gap-3">

                <!-- 安全员签署卡 -->
                <div class="sign-card border rounded p-3">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <span class="sign-icon">&#128737;</span>
                        <span class="fw-semibold">安全员</span>
                    </div>
                    @if (Model.SafetyOfficerSigned)
                    {
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge bg-success">&#10003; 已签署</span>
                            <span class="small text-muted">@Model.SafetyOfficerSignName</span>
                        </div>
                        <div class="text-muted small mt-1">@Model.SafetyOfficerSignAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                    }
                    else if (Model.AdminSignName != null)
                    {
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge bg-info text-dark">管理员代签</span>
                            <span class="small text-muted">@Model.AdminSignName</span>
                        </div>
                        <div class="text-muted small mt-1">@Model.AdminSignAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                    }
                    else
                    {
                        <div class="text-muted small mb-2">&#9711; 待签署</div>
                        @if (canSignAsSO && !Model.SafetyOfficerSigned)
                        {
                            <form asp-action="Sign" asp-route-id="@Model.Id" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-success btn-sm w-100">确认签署</button>
                            </form>
                        }
                    }
                </div>

                <!-- 项目负责人签署卡 -->
                <div class="sign-card border rounded p-3">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <span class="sign-icon">&#128100;</span>
                        <span class="fw-semibold">项目负责人</span>
                    </div>
                    @if (Model.ProjectLeadSigned)
                    {
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge bg-success">&#10003; 已签署</span>
                            <span class="small text-muted">@Model.ProjectLeadSignName</span>
                        </div>
                        <div class="text-muted small mt-1">@Model.ProjectLeadSignAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                    }
                    else if (Model.AdminSignName != null)
                    {
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge bg-info text-dark">管理员代签</span>
                            <span class="small text-muted">@Model.AdminSignName</span>
                        </div>
                        <div class="text-muted small mt-1">@Model.AdminSignAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                    }
                    else
                    {
                        <div class="text-muted small mb-2">&#9711; 待签署</div>
                        @if (canSignAsPL && !Model.ProjectLeadSigned)
                        {
                            <form asp-action="Sign" asp-route-id="@Model.Id" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-success btn-sm w-100">确认签署</button>
                            </form>
                        }
                    }
                </div>

            </div>
        </div>
    </div>
</div>
