@model ResetPasswordViewModel
@{
    ViewData["Title"] = "重置密码";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">重置密码</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">返回列表</a>
</div>

<div class="card" style="max-width: 440px;">
    <div class="card-body">
        <p class="text-muted mb-3">
            为用户 <strong>@Model.UserName</strong> 设置新密码
        </p>

        @Html.ValidationSummary(true, "", new { @class = "alert alert-danger py-2" })

        <form asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="UserName" />

            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label"></label>
                <input asp-for="NewPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
                <div class="form-text">至少8位，包含大写字母、小写字母和数字</div>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-warning">确认重置</button>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
