@model UserListViewModel
@using EquipmentRental.Models.ViewModels
@{
    ViewData["Title"] = "用户管理";
    bool isReadOnly = ViewBag.IsReadOnly == true;
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h4 class="mb-0"><i class="bi bi-people me-2"></i>用户管理</h4>
    @if (!isReadOnly)
    {
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>新增用户
        </a>
    }
</div>

<!-- 过滤栏 -->
<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <input type="text" name="keyword" value="@Model.Keyword"
               class="form-control form-control-sm" placeholder="姓名 / 用户名" />
    </div>
    <div class="col-auto">
        <select name="role" class="form-select form-select-sm">
            <option value="">全部角色</option>
            @foreach (var r in Model.AllRoles)
            {
                <option value="@r" selected="@(Model.Role == r)">@r</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <select name="isActive" class="form-select form-select-sm">
            <option value="">全部状态</option>
            <option value="true"  selected="@(Model.IsActive == true)">启用</option>
            <option value="false" selected="@(Model.IsActive == false)">停用</option>
        </select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary btn-sm">
            <i class="bi bi-funnel me-1"></i>筛选
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">重置</a>
    </div>
</form>

@if (Model.Items.Any())
{
    <div class="table-responsive">
        <table class="table table-hover table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th>用户名</th>
                    <th>真实姓名</th>
                    <th class="d-none d-lg-table-cell">邮箱</th>
                    <th class="d-none d-xl-table-cell">手机</th>
                    <th>角色</th>
                    <th>状态</th>
                    <th class="d-none d-md-table-cell">注册时间</th>
                    @if (!isReadOnly)
                    {
                        <th>操作</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td><code>@item.UserName</code></td>
                        <td>@item.RealName</td>
                        <td class="text-muted small d-none d-lg-table-cell">@item.Email</td>
                        <td class="text-muted small d-none d-xl-table-cell">@item.PhoneNumber</td>
                        <td>
                            <div class="d-inline-flex flex-wrap gap-1">
                                @foreach (var r in item.Roles)
                                {
                                    <span class="badge-soft badge-soft-info">@r</span>
                                }
                            </div>
                        </td>
                        <td>
                            @if (item.IsActive)
                            {
                                @await Html.PartialAsync("_StatusBadge", (Key: "Success", Text: "启用"))
                            }
                            else
                            {
                                @await Html.PartialAsync("_StatusBadge", (Key: "Cancelled", Text: "停用"))
                            }
                        </td>
                        <td class="text-muted small d-none d-md-table-cell">@item.CreatedAt.ToLocalTime().ToDateStr()</td>
                        @if (!isReadOnly)
                        {
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id"
                                   class="btn btn-outline-primary btn-sm" title="编辑" data-bs-toggle="tooltip">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="ToggleActive" asp-route-id="@item.Id"
                                      method="post" class="d-inline"
                                      data-er-confirm="@(item.IsActive ? $"确认停用用户「{item.RealName}」？停用后该用户将无法登录。" : $"确认启用用户「{item.RealName}」？")"
                                      data-er-confirm-title="@(item.IsActive ? "停用用户" : "启用用户")"
                                      data-er-confirm-ok="@(item.IsActive ? "停用" : "启用")"
                                      data-er-confirm-variant="@(item.IsActive ? "warning" : "success")">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="btn btn-sm @(item.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                            title="@(item.IsActive ? "停用" : "启用")" data-bs-toggle="tooltip">
                                        <i class="bi @(item.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                                    </button>
                                </form>
                                <a asp-action="ResetPassword" asp-route-id="@item.Id"
                                   class="btn btn-outline-secondary btn-sm" title="重置密码" data-bs-toggle="tooltip">
                                    <i class="bi bi-key"></i>
                                </a>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    @await Html.PartialAsync("_EmptyState", (
        Icon: "bi-people",
        Title: "暂无用户",
        Hint: "筛选条件下无匹配用户",
        CtaText: (string?)null,
        CtaUrl: (string?)null
    ))
}

@await Html.PartialAsync("_Pagination", new PaginationViewModel
{
    Page = Model.Page,
    TotalPages = Model.TotalPages,
    TotalCount = Model.TotalCount,
    RouteValues = new Dictionary<string, string?>
    {
        ["keyword"]  = Model.Keyword,
        ["role"]     = Model.Role,
        ["isActive"] = Model.IsActive?.ToString()
    }
})
