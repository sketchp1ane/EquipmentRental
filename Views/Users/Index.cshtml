@model UserListViewModel
@{
    ViewData["Title"] = "用户管理";
    bool isReadOnly = ViewBag.IsReadOnly == true;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">用户管理</h4>
    @if (!isReadOnly)
    {
        <a asp-action="Create" class="btn btn-primary btn-sm">+ 新增用户</a>
    }
</div>

<!-- 过滤栏 -->
<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <input type="text" name="keyword" value="@Model.Keyword"
               class="form-control form-control-sm" placeholder="姓名 / 用户名" />
    </div>
    <div class="col-auto">
        <select name="role" class="form-select form-select-sm">
            <option value="">全部角色</option>
            @foreach (var r in Model.AllRoles)
            {
                <option value="@r" selected="@(Model.Role == r)">@r</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <select name="isActive" class="form-select form-select-sm">
            <option value="">全部状态</option>
            <option value="true"  selected="@(Model.IsActive == true)">启用</option>
            <option value="false" selected="@(Model.IsActive == false)">停用</option>
        </select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-secondary btn-sm">筛选</button>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">重置</a>
    </div>
</form>

<!-- 用户表格 -->
<div class="table-responsive">
    <table class="table table-hover table-sm align-middle">
        <thead class="table-light">
            <tr>
                <th>用户名</th>
                <th>真实姓名</th>
                <th>邮箱</th>
                <th>手机</th>
                <th>角色</th>
                <th>状态</th>
                <th>注册时间</th>
                @if (!isReadOnly)
                {
                    <th>操作</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td><code>@item.UserName</code></td>
                    <td>@item.RealName</td>
                    <td class="text-muted small">@item.Email</td>
                    <td class="text-muted small">@item.PhoneNumber</td>
                    <td>
                        @foreach (var r in item.Roles)
                        {
                            <span class="badge bg-secondary me-1">@r</span>
                        }
                    </td>
                    <td>
                        @if (item.IsActive)
                        {
                            <span class="badge bg-success">启用</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">停用</span>
                        }
                    </td>
                    <td class="text-muted small">@item.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</td>
                    @if (!isReadOnly)
                    {
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id"
                               class="btn btn-outline-primary btn-sm">编辑</a>

                            <form asp-action="ToggleActive" asp-route-id="@item.Id"
                                  method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="btn btn-sm @(item.IsActive ? "btn-outline-warning" : "btn-outline-success")">
                                    @(item.IsActive ? "停用" : "启用")
                                </button>
                            </form>

                            <a asp-action="ResetPassword" asp-route-id="@item.Id"
                               class="btn btn-outline-secondary btn-sm">重置密码</a>
                        </td>
                    }
                </tr>
            }
            @if (!Model.Items.Any())
            {
                <tr>
                    <td colspan="@(isReadOnly ? 7 : 8)" class="text-center text-muted py-4">暂无数据</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- 分页 -->
@if (Model.TotalPages > 1)
{
    <nav>
        <ul class="pagination pagination-sm">
            @for (int p = 1; p <= Model.TotalPages; p++)
            {
                <li class="page-item @(p == Model.Page ? "active" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-keyword="@Model.Keyword"
                       asp-route-role="@Model.Role"
                       asp-route-isActive="@Model.IsActive"
                       asp-route-page="@p">@p</a>
                </li>
            }
        </ul>
    </nav>
}
