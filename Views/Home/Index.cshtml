@model HomeIndexViewModel
@{
    ViewData["Title"] = "首页看板";
}

<h4 class="mb-4">首页看板</h4>

@if (Model.PendingActions.Count > 0)
{
    <div class="card mb-4">
        <div class="card-header fw-semibold">待处理事项</div>
        <div class="card-body">
            <div class="row g-2">
                @foreach (var a in Model.PendingActions)
                {
                    <div class="col-6 col-md-4 col-xl-3">
                        <a href="@a.Url" class="text-decoration-none">
                            <div class="border rounded p-2 d-flex justify-content-between align-items-center bg-white">
                                <div>
                                    <div class="small text-muted">@a.Title</div>
                                    <div class="fs-4 fw-bold text-@a.Color">@a.Count</div>
                                </div>
                                <span class="btn btn-outline-@a.Color btn-sm">去处理</span>
                            </div>
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
}

@if (Model.Stats != null)
{
    var s = Model.Stats;
    <!-- 数量卡片 -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-4 col-xl-2">
            <div class="card text-bg-success h-100">
                <div class="card-body py-3">
                    <div class="fs-2 fw-bold">@s.EquipmentIdle</div>
                    <div class="small">空闲设备</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-xl-2">
            <div class="card text-bg-primary h-100">
                <div class="card-body py-3">
                    <div class="fs-2 fw-bold">@s.EquipmentInUse</div>
                    <div class="small">使用中</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-xl-2">
            <div class="card text-bg-warning h-100">
                <div class="card-body py-3">
                    <div class="fs-2 fw-bold">@s.EquipmentMaintenance</div>
                    <div class="small">维修中</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-xl-2">
            <div class="card text-bg-secondary h-100">
                <div class="card-body py-3">
                    <div class="fs-2 fw-bold">@s.EquipmentPendingReview</div>
                    <div class="small">待审核</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-xl-2">
            <div class="card text-bg-info h-100">
                <div class="card-body py-3">
                    <div class="fs-2 fw-bold">@s.ThisMonthOrders</div>
                    <div class="small">本月新增租赁</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-xl-2">
            <div class="card text-bg-danger h-100">
                <div class="card-body py-3">
                    <div class="fs-2 fw-bold">@s.PendingFaults</div>
                    <div class="small">待处理故障</div>
                </div>
            </div>
        </div>
    </div>

    <!-- 折线图 -->
    <div class="card mb-4">
        <div class="card-header fw-semibold">近 6 个月新增租赁趋势</div>
        <div class="card-body">
            <canvas id="rentalTrendChart" height="80"></canvas>
        </div>
    </div>

    <script>
        (function () {
            var trend = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(s.MonthlyTrend));
            var labels  = trend.map(function(d){ return d.Month; });
            var counts  = trend.map(function(d){ return d.Count; });
            new Chart(document.getElementById('rentalTrendChart'), {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: '新增订单数',
                        data: counts,
                        fill: true,
                        tension: 0.3,
                        borderColor: 'rgb(13,110,253)',
                        backgroundColor: 'rgba(13,110,253,0.08)'
                    }]
                },
                options: {
                    scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } },
                    plugins: { legend: { display: false } }
                }
            });
        })();
    </script>
}

@if (Model.ExpiringCerts.Any())
{
    var expiredCount = Model.ExpiringCerts.Count(c => c.IsExpired);
    var soonCount    = Model.ExpiringCerts.Count(c => !c.IsExpired);

    <div class="card border-warning mb-4">
        <div class="card-header bg-warning text-dark fw-semibold">
            证件到期预警
            @if (expiredCount > 0)
            {
                <span class="badge bg-danger ms-2">已过期 @expiredCount</span>
            }
            @if (soonCount > 0)
            {
                <span class="badge bg-warning text-dark border border-dark ms-1">即将到期 @soonCount</span>
            }
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>设备编号</th>
                            <th>设备名称</th>
                            <th>证件类型</th>
                            <th>有效期至</th>
                            <th>状态</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cert in Model.ExpiringCerts)
                        {
                            <tr class="@(cert.IsExpired ? "table-danger" : "table-warning")">
                                <td><code>@cert.EquipmentNo</code></td>
                                <td>@cert.EquipmentName</td>
                                <td>@cert.CertTypeName</td>
                                <td class="small">@cert.ValidTo.ToString("yyyy-MM-dd")</td>
                                <td>
                                    @if (cert.IsExpired)
                                    {
                                        <span class="badge bg-danger">已过期 @(-cert.DaysLeft) 天</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">还剩 @cert.DaysLeft 天</span>
                                    }
                                </td>
                                <td>
                                    @if (User.IsInRole(Roles.Admin) || User.IsInRole(Roles.DeviceAdmin))
                                    {
                                        <a asp-controller="Qualification" asp-action="Index"
                                           asp-route-equipmentId="@cert.EquipmentId"
                                           class="btn btn-outline-warning btn-sm">证件管理</a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-success py-2">
        <small>所有证件均在有效期内（未来 30 天内无到期证件）。</small>
    </div>
}
