@model HomeIndexViewModel
@{
    ViewData["Title"] = "首页看板";

    // Whitelist of allowed Bootstrap color modifiers for pending-action cards.
    var allowedColors = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
    {
        "primary", "secondary", "success", "danger", "warning", "info", "dark", "light"
    };
    string SafeColor(string c) => allowedColors.Contains(c ?? "") ? c! : "primary";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="mb-0"><i class="bi bi-speedometer2 me-2"></i>首页看板</h4>
</div>

@if (Model.PendingActions.Count > 0)
{
    <div class="card er-card mb-4">
        <div class="card-header bg-white fw-semibold border-bottom">
            <i class="bi bi-list-check me-1"></i>待处理事项
        </div>
        <div class="card-body">
            <div class="row g-2">
                @foreach (var a in Model.PendingActions)
                {
                    var c = SafeColor(a.Color);
                    <div class="col-6 col-md-4 col-xl-3">
                        <a href="@a.Url" class="text-decoration-none">
                            <div class="er-card p-2 d-flex justify-content-between align-items-center bg-white">
                                <div>
                                    <div class="small text-muted">@a.Title</div>
                                    <div class="fs-4 fw-bold text-@c">@a.Count</div>
                                </div>
                                <span class="btn btn-outline-@c btn-sm">
                                    去处理<i class="bi bi-arrow-right ms-1"></i>
                                </span>
                            </div>
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
}

@if (Model.Stats != null)
{
    var s = Model.Stats;
    <!-- 数量卡片 -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-4 col-xl">
            <div class="card er-stat-card text-bg-dark h-100">
                <div class="card-body py-3 d-flex justify-content-between align-items-start">
                    <div>
                        <div class="stat-value">@s.EquipmentTotal</div>
                        <div class="stat-label">设备总数</div>
                    </div>
                    <i class="bi bi-box-seam fs-3 opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-xl">
            <div class="card er-stat-card text-bg-primary h-100">
                <div class="card-body py-3 d-flex justify-content-between align-items-start">
                    <div>
                        <div class="stat-value">@s.EquipmentInUse</div>
                        <div class="stat-label">出租中</div>
                    </div>
                    <i class="bi bi-arrow-right-circle fs-3 opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-xl">
            <div class="card er-stat-card text-bg-success h-100">
                <div class="card-body py-3 d-flex justify-content-between align-items-start">
                    <div>
                        <div class="stat-value">@s.EquipmentIdle</div>
                        <div class="stat-label">空闲</div>
                    </div>
                    <i class="bi bi-pause-circle fs-3 opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-xl">
            <div class="card er-stat-card text-bg-warning h-100">
                <div class="card-body py-3 d-flex justify-content-between align-items-start">
                    <div>
                        <div class="stat-value">@s.EquipmentMaintenance</div>
                        <div class="stat-label">维修中</div>
                    </div>
                    <i class="bi bi-tools fs-3 opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-xl">
            <div class="card er-stat-card text-bg-secondary h-100">
                <div class="card-body py-3 d-flex justify-content-between align-items-start">
                    <div>
                        <div class="stat-value">@s.EquipmentPendingReview</div>
                        <div class="stat-label">待审核</div>
                    </div>
                    <i class="bi bi-hourglass-split fs-3 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- 折线图 -->
    <div class="card er-card mb-4">
        <div class="card-header bg-white fw-semibold border-bottom">
            <i class="bi bi-graph-up me-1"></i>近 6 个月新增租赁趋势
        </div>
        <div class="card-body">
            <div class="er-chart">
                <canvas id="rentalTrendChart"></canvas>
            </div>
        </div>
    </div>

    <script>
        (function () {
            var trend = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(s.MonthlyTrend));
            var labels  = trend.map(function(d){ return d.Month; });
            var counts  = trend.map(function(d){ return d.Count; });
            new Chart(document.getElementById('rentalTrendChart'), {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: '新增订单数',
                        data: counts,
                        fill: true,
                        tension: 0.3,
                        borderColor: 'rgb(30,94,255)',
                        backgroundColor: 'rgba(30,94,255,0.08)'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } },
                    plugins: { legend: { display: false } }
                }
            });
        })();
    </script>
}

@if (Model.ExpiringCerts.Any())
{
    var expiredCount = Model.ExpiringCerts.Count(c => c.IsExpired);
    var soonCount    = Model.ExpiringCerts.Count(c => !c.IsExpired);

    <div class="card er-card mb-4">
        <div class="card-header bg-white fw-semibold border-bottom d-flex align-items-center gap-2 flex-wrap">
            <span><i class="bi bi-shield-exclamation me-1 text-warning"></i>证件到期预警</span>
            @if (expiredCount > 0)
            {
                @await Html.PartialAsync("_StatusBadge", (Key: "Expired", Text: $"已过期 {expiredCount}"))
            }
            @if (soonCount > 0)
            {
                @await Html.PartialAsync("_StatusBadge", (Key: "Expiring", Text: $"即将到期 {soonCount}"))
            }
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>设备编号</th>
                            <th>设备名称</th>
                            <th>证件类型</th>
                            <th>有效期至</th>
                            <th>状态</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cert in Model.ExpiringCerts)
                        {
                            <tr>
                                <td><code>@cert.EquipmentNo</code></td>
                                <td>@cert.EquipmentName</td>
                                <td>@cert.CertTypeName</td>
                                <td class="small">@cert.ValidTo.ToString("yyyy-MM-dd")</td>
                                <td>
                                    @if (cert.IsExpired)
                                    {
                                        @await Html.PartialAsync("_StatusBadge",
                                            (Key: "Expired", Text: $"已过期 {-cert.DaysLeft} 天"))
                                    }
                                    else
                                    {
                                        @await Html.PartialAsync("_StatusBadge",
                                            (Key: "Expiring", Text: $"还剩 {cert.DaysLeft} 天"))
                                    }
                                </td>
                                <td>
                                    @if (User.IsInRole(Roles.Admin) || User.IsInRole(Roles.DeviceAdmin))
                                    {
                                        <a asp-controller="Qualification" asp-action="Index"
                                           asp-route-equipmentId="@cert.EquipmentId"
                                           class="btn btn-outline-warning btn-sm">
                                            <i class="bi bi-file-earmark-text me-1"></i>证件管理
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-success py-2 d-flex align-items-center gap-2">
        <i class="bi bi-check-circle-fill"></i>
        <small class="mb-0">所有证件均在有效期内（未来 30 天内无到期证件）。</small>
    </div>
}
