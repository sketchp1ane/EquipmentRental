@model ReturnListViewModel
@using EquipmentRental.Constants
@using EquipmentRental.Models
@using EquipmentRental.Models.ViewModels
@{
    ViewData["Title"] = "退场申请";
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h4 class="mb-0"><i class="bi bi-box-arrow-left me-2"></i>退场申请</h4>
    @if (User.IsInRole(Roles.ProjectLead) || User.IsInRole(Roles.Admin))
    {
        <div class="dropdown">
            <button class="btn btn-primary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown"
                    @(Model.AvailableOrders.Count == 0 ? "disabled" : "")>
                <i class="bi bi-plus-lg me-1"></i>申请退场
                @if (Model.AvailableOrders.Count > 0)
                {
                    <span class="badge bg-light text-dark ms-1">共 @Model.AvailableOrders.Count 个可选</span>
                }
            </button>
            <ul class="dropdown-menu dropdown-menu-end" style="max-height: 320px; overflow-y: auto;">
                @if (Model.AvailableOrders.Count == 0)
                {
                    <li><span class="dropdown-item-text text-muted small">暂无可申请退场的调度单</span></li>
                }
                else
                {
                    <li><h6 class="dropdown-header">选择一张进行中的调度单</h6></li>
                    @foreach (var opt in Model.AvailableOrders)
                    {
                        <li>
                            <a class="dropdown-item" asp-action="Apply" asp-route-orderId="@opt.OrderId">
                                <div class="small">#@opt.OrderId · @opt.ProjectName</div>
                                <div class="text-muted small"><code>@opt.EquipmentNo</code> @opt.EquipmentName</div>
                            </a>
                        </li>
                    }
                }
            </ul>
        </div>
    }
</div>

@if (Model.Items.Any())
{
    <div class="table-responsive">
        <table class="table table-hover table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>调度单</th>
                    <th class="d-none d-md-table-cell">项目名称</th>
                    <th>设备编号</th>
                    <th class="d-none d-lg-table-cell">申请人</th>
                    <th>实际退场日期</th>
                    <th class="d-none d-xl-table-cell">提交时间</th>
                    <th>状态</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td class="text-muted small">#@item.Id</td>
                        <td>
                            <a asp-controller="Dispatch" asp-action="OrderDetails" asp-route-id="@item.OrderId">#@item.OrderId</a>
                        </td>
                        <td class="text-truncate-2 d-none d-md-table-cell" style="max-width:200px">@item.ProjectName</td>
                        <td><code>@item.EquipmentNo</code></td>
                        <td class="text-muted small d-none d-lg-table-cell">@item.ApplicantName</td>
                        <td class="text-nowrap">@item.ActualReturnDate.ToDateStr()</td>
                        <td class="text-muted small text-nowrap d-none d-xl-table-cell">@item.CreatedAt.ToLocalTime().ToDateTimeStr()</td>
                        <td>
                            @if (item.Status == ReturnApplicationStatus.PendingEvaluation)
                            {
                                @await Html.PartialAsync("_StatusBadge", (Key: "Pending", Text: "待评价"))
                            }
                            else
                            {
                                @await Html.PartialAsync("_StatusBadge", (Key: "Success", Text: "已完成"))
                            }
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id"
                               class="btn btn-outline-secondary btn-sm" title="详情" data-bs-toggle="tooltip">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    @await Html.PartialAsync("_EmptyState", (
        Icon: "bi-box-arrow-left",
        Title: "暂无退场申请记录",
        Hint: "尚未有退场申请",
        CtaText: (string?)null,
        CtaUrl: (string?)null
    ))
}

@await Html.PartialAsync("_Pagination", new PaginationViewModel
{
    Page = Model.Page,
    TotalPages = Model.TotalPages,
    TotalCount = Model.TotalCount,
    RouteValues = new Dictionary<string, string?>()
})
