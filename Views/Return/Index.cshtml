@model ReturnListViewModel
@using EquipmentRental.Constants
@using EquipmentRental.Models
@using EquipmentRental.Models.ViewModels
@{
    ViewData["Title"] = "退场申请";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">退场申请</h4>
    @if (User.IsInRole(Roles.ProjectLead) || User.IsInRole(Roles.Admin))
    {
        <div class="dropdown">
            <button class="btn btn-primary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown"
                    @(Model.AvailableOrders.Count == 0 ? "disabled" : "")>
                申请退场
            </button>
            <ul class="dropdown-menu dropdown-menu-end" style="max-height: 320px; overflow-y: auto;">
                @if (Model.AvailableOrders.Count == 0)
                {
                    <li><span class="dropdown-item-text text-muted small">暂无可申请退场的调度单</span></li>
                }
                else
                {
                    <li><h6 class="dropdown-header">选择一张进行中的调度单</h6></li>
                    @foreach (var opt in Model.AvailableOrders)
                    {
                        <li>
                            <a class="dropdown-item" asp-action="Apply" asp-route-orderId="@opt.OrderId">
                                <div class="small">#@opt.OrderId · @opt.ProjectName</div>
                                <div class="text-muted small"><code>@opt.EquipmentNo</code> @opt.EquipmentName</div>
                            </a>
                        </li>
                    }
                }
            </ul>
        </div>
    }
</div>

@if (Model.Items.Count == 0)
{
    <div class="text-center py-5 text-muted">暂无退场申请记录</div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>调度单</th>
                        <th>项目名称</th>
                        <th>设备编号</th>
                        <th>申请人</th>
                        <th>实际退场日期</th>
                        <th>提交时间</th>
                        <th>状态</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>#@item.Id</td>
                            <td>
                                <a asp-controller="Dispatch" asp-action="OrderDetails" asp-route-id="@item.OrderId">#@item.OrderId</a>
                            </td>
                            <td>@item.ProjectName</td>
                            <td><code>@item.EquipmentNo</code></td>
                            <td>@item.ApplicantName</td>
                            <td>@item.ActualReturnDate.ToString("yyyy-MM-dd")</td>
                            <td>@item.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                @if (item.Status == ReturnApplicationStatus.PendingEvaluation)
                                {
                                    <span class="badge bg-warning text-dark">待评价</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">已完成</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-outline-secondary btn-sm">详情</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination pagination-sm justify-content-center">
                @for (int p = 1; p <= Model.TotalPages; p++)
                {
                    <li class="page-item @(p == Model.Page ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@p">@p</a>
                    </li>
                }
            </ul>
        </nav>
    }

    <div class="text-muted small text-end mt-2">共 @Model.TotalCount 条记录</div>
}
