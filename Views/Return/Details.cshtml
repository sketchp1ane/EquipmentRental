@model ReturnDetailViewModel
@using EquipmentRental.Models
@using EquipmentRental.Models.ViewModels
@{
    ViewData["Title"] = $"退场申请 #{Model.Id}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">退场申请 <small class="text-muted fs-6">#@Model.Id</small></h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">返回列表</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible py-2 mb-3" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible py-2 mb-3" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- 状态横幅 -->
@if (Model.Status == ReturnApplicationStatus.PendingEvaluation)
{
    <div class="alert alert-warning py-2 mb-3">
        <strong>待评价</strong> — 设备管理员尚未完成验收评价。
    </div>
}
else
{
    <div class="alert alert-success py-2 mb-3">
        <strong>已完成</strong> — 退场评价已提交，押金已核算。
    </div>
}

<div class="row g-4">
    <!-- 左列：申请信息 + 评价结果 -->
    <div class="col-lg-8">
        <div class="card mb-3">
            <div class="card-header fw-semibold">退场申请信息</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3">调度单</dt>
                    <dd class="col-sm-9">
                        <a asp-controller="Dispatch" asp-action="OrderDetails" asp-route-id="@Model.OrderId">#@Model.OrderId</a>
                        &nbsp;@Model.ProjectName
                    </dd>
                    <dt class="col-sm-3">设备</dt>
                    <dd class="col-sm-9"><code>@Model.EquipmentNo</code> @Model.EquipmentName</dd>
                    <dt class="col-sm-3">押金金额</dt>
                    <dd class="col-sm-9">¥ @Model.Deposit.ToString("N2")</dd>
                    <dt class="col-sm-3">申请人</dt>
                    <dd class="col-sm-9">@Model.ApplicantName</dd>
                    <dt class="col-sm-3">实际退场日期</dt>
                    <dd class="col-sm-9">@Model.ActualReturnDate.ToString("yyyy-MM-dd")</dd>
                    <dt class="col-sm-3">提交时间</dt>
                    <dd class="col-sm-9">@Model.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</dd>
                    @if (!string.IsNullOrWhiteSpace(Model.ConditionDesc))
                    {
                        <dt class="col-sm-3">设备状况描述</dt>
                        <dd class="col-sm-9">
                            <p class="mb-0" style="white-space:pre-wrap">@Model.ConditionDesc</p>
                        </dd>
                    }
                </dl>
            </div>
        </div>

        @if (Model.Evaluation != null)
        {
            var e = Model.Evaluation;
            <div class="card mb-3">
                <div class="card-header fw-semibold">退场评价结果</div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-3">外观评分</dt>
                        <dd class="col-sm-9">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <span class="@(i <= e.AppearanceScore ? "text-warning" : "text-muted")">&#9733;</span>
                            }
                            <span class="ms-1 text-muted small">(@e.AppearanceScore / 5)</span>
                        </dd>
                        <dt class="col-sm-3">功能评分</dt>
                        <dd class="col-sm-9">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <span class="@(i <= e.FunctionScore ? "text-warning" : "text-muted")">&#9733;</span>
                            }
                            <span class="ms-1 text-muted small">(@e.FunctionScore / 5)</span>
                        </dd>
                        @if (!string.IsNullOrWhiteSpace(e.DamageDesc))
                        {
                            <dt class="col-sm-3">损耗描述</dt>
                            <dd class="col-sm-9">
                                <p class="mb-0" style="white-space:pre-wrap">@e.DamageDesc</p>
                            </dd>
                        }
                        <dt class="col-sm-3">损耗扣款</dt>
                        <dd class="col-sm-9">¥ @e.Deduction.ToString("N2")</dd>
                        <dt class="col-sm-3">押金退还</dt>
                        <dd class="col-sm-9 fw-semibold text-success">¥ @e.RefundAmount.ToString("N2")</dd>
                        <dt class="col-sm-3">退场后状态</dt>
                        <dd class="col-sm-9">@e.NewEquipmentStatus</dd>
                        @if (!string.IsNullOrWhiteSpace(e.Remark))
                        {
                            <dt class="col-sm-3">综合备注</dt>
                            <dd class="col-sm-9">
                                <p class="mb-0" style="white-space:pre-wrap">@e.Remark</p>
                            </dd>
                        }
                        <dt class="col-sm-3">评价人</dt>
                        <dd class="col-sm-9">@e.EvaluatorName</dd>
                        <dt class="col-sm-3">评价时间</dt>
                        <dd class="col-sm-9">@e.EvaluatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</dd>
                    </dl>
                </div>
            </div>
        }
    </div>

    <!-- 右列：操作区 -->
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header fw-semibold">操作</div>
            <div class="card-body">
                @if (Model.CanEvaluate && User.IsInRole(EquipmentRental.Constants.Roles.DeviceAdmin))
                {
                    <p class="text-muted small mb-3">设备已退场，请完成验收后填写评价并核算押金退还金额。</p>
                    <a asp-action="Evaluate" asp-route-id="@Model.Id"
                       class="btn btn-primary w-100">填写退场评价</a>
                }
                else if (Model.Status == ReturnApplicationStatus.Complete)
                {
                    <div class="text-success fw-semibold">&#10003; 退场评价已完成</div>
                    <div class="text-muted small mt-1">押金退还：¥ @Model.Evaluation?.RefundAmount.ToString("N2")</div>
                }
                else
                {
                    <div class="text-muted small">当前状态下无可用操作，或您无操作权限。</div>
                }
            </div>
        </div>
    </div>
</div>
