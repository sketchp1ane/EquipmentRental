@*
    Attachment thumbnail grid. Used across Equipment/Qualification/Fault/Inspection
    to render uploaded files uniformly.

    Each AttachmentVm renders as:
        - <img> thumbnail for images (IsImage=true), otherwise a file-icon card
        - caption with filename + created date
        - optional delete button (uses data-er-confirm for unified modal)

    Usage:
        @await Html.PartialAsync("_AttachmentList", items)  // items: IEnumerable<AttachmentVm>
*@
@model IEnumerable<AttachmentVm>
@{
    var items = (Model ?? Array.Empty<AttachmentVm>()).ToList();
}

@if (items.Count == 0)
{
    <div class="text-muted small py-2"><i class="bi bi-inbox me-1"></i>暂无附件</div>
}
else
{
    <div class="row g-2">
        @foreach (var a in items)
        {
            <div class="col-6 col-md-4 col-lg-3">
                <div class="er-card h-100 p-2 d-flex flex-column">
                    <a href="@a.Url" target="_blank" class="d-block text-center mb-2 text-decoration-none">
                        @if (a.IsImage)
                        {
                            <img src="@a.Url" alt="@a.Name"
                                 class="img-fluid rounded"
                                 style="max-height:120px;object-fit:cover;width:100%" />
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center bg-light rounded"
                                 style="height:120px">
                                <i class="bi bi-file-earmark-text text-secondary" style="font-size:2.5rem"></i>
                            </div>
                        }
                    </a>
                    <div class="small text-truncate-2 mb-1" title="@a.Name">@(a.Name ?? "附件")</div>
                    @if (!string.IsNullOrWhiteSpace(a.CreatedAt))
                    {
                        <div class="text-muted small">@a.CreatedAt</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(a.DeleteFormAction))
                    {
                        <form method="post" action="@a.DeleteFormAction" class="mt-auto"
                              data-er-confirm="确认删除该附件？删除后无法恢复。"
                              data-er-confirm-title="删除附件"
                              data-er-confirm-ok="删除">
                            @Html.AntiForgeryToken()
                            @if (a.DeleteFormFields != null)
                            {
                                foreach (var kv in a.DeleteFormFields)
                                {
                                    <input type="hidden" name="@kv.Key" value="@kv.Value" />
                                }
                            }
                            <button type="submit" class="btn btn-sm btn-outline-danger w-100">
                                <i class="bi bi-trash me-1"></i>删除
                            </button>
                        </form>
                    }
                </div>
            </div>
        }
    </div>
}
