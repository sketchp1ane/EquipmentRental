@*
    Shared date range filter — used by Report/Utilization, Report/Rental, Report/Safety.

    Model: (DateTime From, DateTime To, string FromName = "from", string ToName = "to", string SubmitText = "查询")

    Renders: date inputs + preset shortcuts (近7天 / 近30天 / 本月 / 上月) + 查询 button.
    Presets are client-side only (fill both inputs, do not submit).
*@
@model (DateOnly From, DateOnly To, string FromName, string ToName, string SubmitText)
@{
    var fromName = string.IsNullOrEmpty(Model.FromName) ? "from" : Model.FromName;
    var toName   = string.IsNullOrEmpty(Model.ToName)   ? "to"   : Model.ToName;
    var submit   = string.IsNullOrEmpty(Model.SubmitText) ? "查询" : Model.SubmitText;
}
<form method="get" class="er-card p-3 mb-4">
    <div class="row g-2 align-items-end">
        <div class="col-12 col-sm-6 col-md-auto">
            <label class="form-label mb-1 small">开始日期</label>
            <input type="date" name="@fromName" class="form-control form-control-sm er-date-from"
                   value="@Model.From.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-12 col-sm-6 col-md-auto">
            <label class="form-label mb-1 small">结束日期</label>
            <input type="date" name="@toName" class="form-control form-control-sm er-date-to"
                   value="@Model.To.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-12 col-md-auto">
            <div class="d-flex flex-wrap gap-1 er-date-presets">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-preset="7">近 7 天</button>
                <button type="button" class="btn btn-outline-secondary btn-sm" data-preset="30">近 30 天</button>
                <button type="button" class="btn btn-outline-secondary btn-sm" data-preset="month">本月</button>
                <button type="button" class="btn btn-outline-secondary btn-sm" data-preset="lastmonth">上月</button>
            </div>
        </div>
        <div class="col-12 col-md-auto ms-md-auto">
            <button type="submit" class="btn btn-primary btn-sm w-100 w-md-auto">
                <i class="bi bi-search me-1"></i>@submit
            </button>
        </div>
    </div>
</form>

<script>
    (function () {
        var form = document.currentScript.previousElementSibling;
        while (form && form.tagName !== 'FORM') form = form.previousElementSibling;
        if (!form) return;
        var fromEl = form.querySelector('.er-date-from');
        var toEl   = form.querySelector('.er-date-to');
        function fmt(d) { return d.toISOString().slice(0, 10); }
        form.querySelectorAll('.er-date-presets [data-preset]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var p = btn.dataset.preset;
                var now = new Date();
                var end = new Date(now.getFullYear(), now.getMonth(), now.getDate());
                var start = new Date(end);
                if (p === '7') start.setDate(end.getDate() - 6);
                else if (p === '30') start.setDate(end.getDate() - 29);
                else if (p === 'month') {
                    start = new Date(now.getFullYear(), now.getMonth(), 1);
                    end = new Date(now.getFullYear(), now.getMonth() + 1, 0);
                }
                else if (p === 'lastmonth') {
                    start = new Date(now.getFullYear(), now.getMonth() - 1, 1);
                    end = new Date(now.getFullYear(), now.getMonth(), 0);
                }
                fromEl.value = fmt(start);
                toEl.value = fmt(end);
            });
        });
    })();
</script>
