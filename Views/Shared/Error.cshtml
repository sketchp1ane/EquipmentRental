@model ErrorViewModel
@{
    ViewData["Title"] = Model.StatusCode switch
    {
        404 => "页面不存在",
        403 => "无访问权限",
        400 => "请求无效",
        _   => "服务器错误"
    };
    Layout = "_Layout";
}

<div class="d-flex flex-column align-items-center justify-content-center py-5 text-center">

    <div class="display-1 fw-bold text-secondary mb-2">@Model.StatusCode</div>

    @switch (Model.StatusCode)
    {
        case 404:
            <h4 class="mb-2">页面不存在</h4>
            <p class="text-muted mb-4">您访问的页面已被移除，或地址输入有误。</p>
            break;
        case 403:
            <h4 class="mb-2">无访问权限</h4>
            <p class="text-muted mb-4">您没有权限访问该页面，请联系管理员。</p>
            break;
        case 400:
            <h4 class="mb-2">请求无效</h4>
            <p class="text-muted mb-4">请求格式不正确，请返回重试。</p>
            break;
        default:
            <h4 class="mb-2">服务器内部错误</h4>
            <p class="text-muted mb-4">服务器处理请求时出现了问题，请稍后再试。</p>
            @if (Model.ShowRequestId)
            {
                <p class="small text-muted mb-4">请求 ID：<code>@Model.RequestId</code></p>
            }
            break;
    }

    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">返回首页</a>

</div>
