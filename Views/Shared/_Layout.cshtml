<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 租赁设备管理平台</title>
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/bootstrap-icons.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/summernote/summernote-bs5.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column vh-100">

    <!-- Libraries loaded early so inline <script> blocks inside views can reference them -->
    <script src="~/lib/jquery/jquery.min.js" asp-append-version="true"></script>
    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js" asp-append-version="true"></script>
    <script src="~/lib/chartjs/chart.umd.min.js" asp-append-version="true"></script>
    <script src="~/lib/summernote/summernote-bs5.min.js" asp-append-version="true"></script>

    @{
        // Sidebar markup rendered once, inserted in both desktop and mobile containers.
        bool isAuth = User.Identity?.IsAuthenticated == true;
    }

    <!-- Top Navbar -->
    <nav class="navbar navbar-dark bg-dark flex-shrink-0 px-3 py-2">
        @if (isAuth)
        {
            <button class="btn btn-dark border-0 sidebar-mobile-toggle me-2"
                    type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarOffcanvas"
                    aria-controls="sidebarOffcanvas" aria-label="菜单">
                <i class="bi bi-list fs-4"></i>
            </button>
        }
        <a class="navbar-brand fw-semibold d-flex align-items-center gap-2" href="/">
            <i class="bi bi-tools"></i>
            <span>租赁设备管理平台</span>
        </a>
        <div class="d-flex align-items-center gap-3 ms-auto">
            @if (isAuth)
            {
                <!-- Notification bell -->
                <div class="dropdown" id="notif-dropdown">
                    <button class="btn btn-dark btn-sm position-relative border-0"
                            data-bs-toggle="dropdown" data-bs-auto-close="outside"
                            aria-expanded="false" title="站内消息">
                        <i class="bi bi-bell-fill fs-5" aria-hidden="true"></i>
                        <span id="notif-badge"
                              class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none"
                              style="font-size: 0.6rem;">0</span>
                    </button>
                    <div class="dropdown-menu dropdown-menu-end notif-dropdown-menu">
                        <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom">
                            <span class="fw-semibold">站内消息</span>
                            <button type="button" id="notif-mark-all"
                                    class="btn btn-link btn-sm p-0 text-decoration-none">
                                全部标为已读
                            </button>
                        </div>
                        <div id="notif-list" class="notif-list">
                            <div class="text-muted small text-center py-4">加载中…</div>
                        </div>
                    </div>
                </div>
                @Html.AntiForgeryToken()
                <div class="dropdown">
                    <button class="btn btn-outline-light btn-sm dropdown-toggle" data-bs-toggle="dropdown">
                        <i class="bi bi-person-circle me-1"></i>@User.Identity!.Name
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="/Account/Profile"><i class="bi bi-person me-2"></i>个人信息</a></li>
                        <li><hr class="dropdown-divider" /></li>
                        <li>
                            <form action="/Account/Logout" method="post">
                                @Html.AntiForgeryToken()
                                <button class="dropdown-item text-danger" type="submit"><i class="bi bi-box-arrow-right me-2"></i>退出登录</button>
                            </form>
                        </li>
                    </ul>
                </div>
            }
        </div>
    </nav>

    <div class="d-flex flex-grow-1 overflow-hidden">

        <!-- Sidebar (desktop ≥lg) -->
        @if (isAuth)
        {
            <nav class="sidebar sidebar-desktop d-flex flex-column bg-dark text-white p-2 flex-shrink-0 overflow-y-auto">
                @await Html.PartialAsync("_SidebarNav")
            </nav>

            <!-- Sidebar (off-canvas <lg) -->
            <div class="offcanvas offcanvas-start sidebar-offcanvas" tabindex="-1" id="sidebarOffcanvas" aria-labelledby="sidebarOffcanvasLabel">
                <div class="offcanvas-header border-bottom border-secondary">
                    <h6 class="offcanvas-title text-white mb-0" id="sidebarOffcanvasLabel">
                        <i class="bi bi-tools me-2"></i>菜单
                    </h6>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                </div>
                <div class="offcanvas-body p-2">
                    @await Html.PartialAsync("_SidebarNav")
                </div>
            </div>
        }

        <!-- Main Content -->
        <main id="main-content" class="flex-grow-1 p-4 bg-light">
            @RenderBody()
        </main>

    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await Html.PartialAsync("_FlashToast")
    @if (isAuth)
    {
        <script>
            (function () {
                const badge = document.getElementById('notif-badge');
                const list  = document.getElementById('notif-list');
                const dropdown = document.getElementById('notif-dropdown');
                if (!badge || !list || !dropdown) return;

                function token() {
                    const el = document.querySelector('input[name="__RequestVerificationToken"]');
                    return el ? el.value : '';
                }
                function setBadge(n) {
                    if (n > 0) {
                        badge.textContent = n > 99 ? '99+' : n;
                        badge.classList.remove('d-none');
                    } else {
                        badge.classList.add('d-none');
                    }
                }
                function renderItems(items) {
                    if (!items.length) {
                        list.innerHTML = '<div class="er-empty py-4"><div class="er-empty-icon" style="font-size:2rem"><i class="bi bi-bell-slash"></i></div><div class="er-empty-hint">暂无消息</div></div>';
                        return;
                    }
                    list.innerHTML = items.map(n => {
                        const cls = n.isRead ? 'text-muted' : 'fw-semibold';
                        const dot = n.isRead ? '' : '<span class="badge bg-primary ms-1">新</span>';
                        return `<a href="#" class="d-block px-3 py-2 border-bottom text-decoration-none notif-item"
                                   data-id="${n.id}" data-url="${n.relatedUrl || ''}">
                            <div class="${cls}">${n.title} ${dot}</div>
                            <div class="small text-muted text-truncate">${n.content}</div>
                            <div class="small text-muted">${n.createdAt}</div>
                        </a>`;
                    }).join('');
                    list.querySelectorAll('.notif-item').forEach(el => {
                        el.addEventListener('click', async (e) => {
                            e.preventDefault();
                            const id = el.getAttribute('data-id');
                            const url = el.getAttribute('data-url');
                            const fd = new FormData();
                            await fetch('/Notification/MarkRead/' + id, {
                                method: 'POST',
                                headers: { 'RequestVerificationToken': token() },
                                body: fd
                            });
                            if (url) window.location.href = url;
                            else refresh();
                        });
                    });
                }
                async function refresh() {
                    try {
                        const res = await fetch('/Notification/Recent', { credentials: 'same-origin' });
                        if (!res.ok) return;
                        const data = await res.json();
                        setBadge(data.unread || 0);
                        renderItems(data.items || []);
                    } catch { /* ignore */ }
                }

                refresh();
                setInterval(refresh, 60000);

                document.getElementById('notif-mark-all').addEventListener('click', async () => {
                    const fd = new FormData();
                    await fetch('/Notification/MarkAllRead', {
                        method: 'POST',
                        headers: { 'RequestVerificationToken': token() },
                        body: fd
                    });
                    refresh();
                });
            })();
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
