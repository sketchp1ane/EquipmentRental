<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 租赁设备管理平台</title>
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/summernote/summernote-bs5.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body { overflow: hidden; }
        .sidebar { width: 220px; min-height: 0; }
        .sidebar .nav-link { border-radius: 6px; padding: 6px 12px; font-size: 0.9rem; }
        .sidebar .nav-link:hover { background-color: rgba(255,255,255,0.12); }
        .sidebar .section-label { font-size: 0.7rem; letter-spacing: 0.08em; padding: 4px 12px; }
        #main-content { overflow-y: auto; }
    </style>
</head>
<body class="d-flex flex-column vh-100">

    <!-- Top Navbar -->
    <nav class="navbar navbar-dark bg-dark flex-shrink-0 px-3 py-2">
        <a class="navbar-brand fw-semibold" href="/">&#128295; 租赁设备管理平台</a>
        <div class="d-flex align-items-center gap-3 ms-auto">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <!-- Notification bell -->
                <div class="dropdown" id="notif-dropdown">
                    <button class="btn btn-dark btn-sm position-relative border-0"
                            data-bs-toggle="dropdown" data-bs-auto-close="outside"
                            aria-expanded="false" title="站内消息">
                        <span aria-hidden="true" style="font-size: 1.1rem;">🔔</span>
                        <span id="notif-badge"
                              class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none"
                              style="font-size: 0.6rem;">0</span>
                    </button>
                    <div class="dropdown-menu dropdown-menu-end p-0"
                         style="width: 340px; max-height: 420px;">
                        <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom">
                            <span class="fw-semibold">站内消息</span>
                            <button type="button" id="notif-mark-all"
                                    class="btn btn-link btn-sm p-0 text-decoration-none">
                                全部标为已读
                            </button>
                        </div>
                        <div id="notif-list" style="max-height: 340px; overflow-y: auto;">
                            <div class="text-muted small text-center py-4">加载中…</div>
                        </div>
                    </div>
                </div>
                @Html.AntiForgeryToken()
                <div class="dropdown">
                    <button class="btn btn-outline-light btn-sm dropdown-toggle" data-bs-toggle="dropdown">
                        @User.Identity.Name
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="/Account/Profile">个人信息</a></li>
                        <li><hr class="dropdown-divider" /></li>
                        <li>
                            <form action="/Account/Logout" method="post">
                                @Html.AntiForgeryToken()
                                <button class="dropdown-item text-danger" type="submit">退出登录</button>
                            </form>
                        </li>
                    </ul>
                </div>
            }
        </div>
    </nav>

    <div class="d-flex flex-grow-1 overflow-hidden">

        <!-- Sidebar -->
        @if (User.Identity?.IsAuthenticated == true)
        {
            <nav class="sidebar d-flex flex-column bg-dark text-white p-2 flex-shrink-0 overflow-y-auto">
                <ul class="nav nav-pills flex-column gap-1">

                    <!-- 首页看板 -->
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Home" asp-action="Index">首页看板</a>
                    </li>

                    <!-- 设备管理 -->
                    @if (User.IsInRole(Roles.Admin) || User.IsInRole(Roles.DeviceAdmin) ||
                         User.IsInRole(Roles.Dispatcher) || User.IsInRole(Roles.ProjectLead) ||
                         User.IsInRole(Roles.SafetyOfficer) || User.IsInRole(Roles.Auditor))
                    {
                        <li class="nav-item mt-2">
                            <span class="section-label text-secondary text-uppercase d-block">设备管理</span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Equipment" asp-action="Index">设备台账</a>
                        </li>
                    }
                    @if (User.IsInRole(Roles.Admin) || User.IsInRole(Roles.DeviceAdmin))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Equipment" asp-action="Create">设备入库</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Audit" asp-action="Index">资质审核</a>
                        </li>
                    }

                    <!-- 调度管理 -->
                    @if (User.IsInRole(Roles.Admin) || User.IsInRole(Roles.Dispatcher) ||
                         User.IsInRole(Roles.ProjectLead) || User.IsInRole(Roles.Auditor))
                    {
                        <li class="nav-item mt-2">
                            <span class="section-label text-secondary text-uppercase d-block">调度管理</span>
                        </li>
                    }
                    @if (User.IsInRole(Roles.Admin) || User.IsInRole(Roles.ProjectLead))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Dispatch" asp-action="Request">用车申请</a>
                        </li>
                    }
                    @if (User.IsInRole(Roles.Admin) || User.IsInRole(Roles.Dispatcher))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Dispatch" asp-action="Index">用车申请审批</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Dispatch" asp-action="Calendar">调度日历</a>
                        </li>
                    }
                    @if (User.IsInRole(Roles.Auditor))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Dispatch" asp-action="Index">用车申请审批</a>
                        </li>
                    }
                    @if (User.IsInRole(Roles.Admin) || User.IsInRole(Roles.Dispatcher) ||
                         User.IsInRole(Roles.ProjectLead) || User.IsInRole(Roles.Auditor))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Dispatch" asp-action="Orders">调度单</a>
                        </li>
                    }

                    <!-- 现场管理 -->
                    @if (User.IsInRole(Roles.Admin) || User.IsInRole(Roles.SafetyOfficer) ||
                         User.IsInRole(Roles.ProjectLead) || User.IsInRole(Roles.Auditor) ||
                         User.IsInRole(Roles.Dispatcher))
                    {
                        <li class="nav-item mt-2">
                            <span class="section-label text-secondary text-uppercase d-block">现场管理</span>
                        </li>
                    }
                    @if (User.IsInRole(Roles.Admin) || User.IsInRole(Roles.ProjectLead))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Verification" asp-action="Verify">进场核验</a>
                        </li>
                    }
                    @if (User.IsInRole(Roles.Admin) || User.IsInRole(Roles.Dispatcher) ||
                         User.IsInRole(Roles.Auditor))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Verification" asp-action="List">核验记录</a>
                        </li>
                    }
                    @if (User.IsInRole(Roles.Admin) || User.IsInRole(Roles.SafetyOfficer) ||
                         User.IsInRole(Roles.ProjectLead) || User.IsInRole(Roles.Auditor))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Safety" asp-action="List">安全交底</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Inspection" asp-action="Index">巡检记录</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Fault" asp-action="Index">故障上报</a>
                        </li>
                    }

                    <!-- 退场管理 -->
                    @if (User.IsInRole(Roles.Admin) || User.IsInRole(Roles.DeviceAdmin) ||
                         User.IsInRole(Roles.ProjectLead) || User.IsInRole(Roles.Auditor))
                    {
                        <li class="nav-item mt-2">
                            <span class="section-label text-secondary text-uppercase d-block">退场管理</span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Return" asp-action="Index">退场评价</a>
                        </li>
                    }

                    <!-- 统计报表 -->
                    <li class="nav-item mt-2">
                        <span class="section-label text-secondary text-uppercase d-block">统计报表</span>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Report" asp-action="Rental">租赁统计</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Report" asp-action="Utilization">利用率</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Report" asp-action="Safety">安全记录</a>
                    </li>

                    <!-- 系统管理 -->
                    @if (User.IsInRole(Roles.Admin) || User.IsInRole(Roles.Auditor))
                    {
                        <li class="nav-item mt-2">
                            <span class="section-label text-secondary text-uppercase d-block">系统管理</span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Users" asp-action="Index">用户管理</a>
                        </li>
                    }

                </ul>
            </nav>
        }

        <!-- Main Content -->
        <main id="main-content" class="flex-grow-1 p-4 bg-light">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </main>

    </div>

    <script src="~/lib/jquery/jquery.min.js"></script>
    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/chartjs/chart.umd.min.js"></script>
    <script src="~/lib/summernote/summernote-bs5.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <script>
            (function () {
                const badge = document.getElementById('notif-badge');
                const list  = document.getElementById('notif-list');
                const dropdown = document.getElementById('notif-dropdown');
                if (!badge || !list || !dropdown) return;

                function token() {
                    const el = document.querySelector('input[name="__RequestVerificationToken"]');
                    return el ? el.value : '';
                }
                function setBadge(n) {
                    if (n > 0) {
                        badge.textContent = n > 99 ? '99+' : n;
                        badge.classList.remove('d-none');
                    } else {
                        badge.classList.add('d-none');
                    }
                }
                function renderItems(items) {
                    if (!items.length) {
                        list.innerHTML = '<div class="text-muted small text-center py-4">暂无消息</div>';
                        return;
                    }
                    list.innerHTML = items.map(n => {
                        const cls = n.isRead ? 'text-muted' : 'fw-semibold';
                        const dot = n.isRead ? '' : '<span class="badge bg-primary ms-1">新</span>';
                        return `<a href="#" class="d-block px-3 py-2 border-bottom text-decoration-none notif-item"
                                   data-id="${n.id}" data-url="${n.relatedUrl || ''}">
                            <div class="${cls}">${n.title} ${dot}</div>
                            <div class="small text-muted text-truncate">${n.content}</div>
                            <div class="small text-muted">${n.createdAt}</div>
                        </a>`;
                    }).join('');
                    list.querySelectorAll('.notif-item').forEach(el => {
                        el.addEventListener('click', async (e) => {
                            e.preventDefault();
                            const id = el.getAttribute('data-id');
                            const url = el.getAttribute('data-url');
                            const fd = new FormData();
                            await fetch('/Notification/MarkRead/' + id, {
                                method: 'POST',
                                headers: { 'RequestVerificationToken': token() },
                                body: fd
                            });
                            if (url) window.location.href = url;
                            else refresh();
                        });
                    });
                }
                async function refresh() {
                    try {
                        const res = await fetch('/Notification/Recent', { credentials: 'same-origin' });
                        if (!res.ok) return;
                        const data = await res.json();
                        setBadge(data.unread || 0);
                        renderItems(data.items || []);
                    } catch { /* ignore */ }
                }

                refresh();
                setInterval(refresh, 60000);

                document.getElementById('notif-mark-all').addEventListener('click', async () => {
                    const fd = new FormData();
                    await fetch('/Notification/MarkAllRead', {
                        method: 'POST',
                        headers: { 'RequestVerificationToken': token() },
                        body: fd
                    });
                    refresh();
                });
            })();
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
